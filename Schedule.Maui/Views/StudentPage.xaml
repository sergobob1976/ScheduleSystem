<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Schedule.Maui.Views.StudentPage"
             Title="Розклад занять">

    <Grid RowDefinitions="Auto, Auto, *" Padding="15" RowSpacing="10">

        <HorizontalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <DatePicker Date="{Binding SelectedDate}" Format="dd.MM.yyyy" WidthRequest="150"/>
            <Button Text="🔄 Оновити з сервера" 
                    Clicked="OnSyncClicked" 
                    BackgroundColor="#512BD4" 
                    TextColor="White"
                    FontAttributes="Bold"/>
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="5">
            <Label Text="Оберіть групу:" FontAttributes="Bold" TextColor="Gray"/>
            <Picker ItemsSource="{Binding Groups}" 
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedGroup}" />
        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="2" 
                           IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           VerticalOptions="Center" 
                           HorizontalOptions="Center" />

        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding VisibleLessons}" 
                        IsVisible="{Binding IsNotBusy}"
                        Margin="0,10,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="LightGray" StrokeThickness="1" Padding="15" Margin="0,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="5">

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding LessonPosition, StringFormat='Пара №{0}'}" FontAttributes="Bold" TextColor="#512BD4"/>
                                <Label Text="{Binding LessonDate, StringFormat='{0:HH:mm}'}" TextColor="DarkGray" FontAttributes="Italic"/>
                            </HorizontalStackLayout>

                            <Label Text="{Binding Discipline.Name}" FontSize="16" FontAttributes="Bold" TextColor="Black"/>

                            <HorizontalStackLayout Spacing="5">
                                <Label Text="👨‍🏫 Викладач:" TextColor="Gray"/>
                                <Label Text="{Binding Teacher.LastName}" TextColor="#333333"/>
                                <Label Text="{Binding Teacher.FirstName}" TextColor="#333333"/>
                                <Label Text="{Binding Teacher.MiddleName}" TextColor="#333333"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="5">
                                <Label Text="📍 Аудиторія:" TextColor="Gray"/>
                                <Label Text="{Binding ClassRoom.Name}" FontAttributes="Bold" TextColor="Black"/>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>