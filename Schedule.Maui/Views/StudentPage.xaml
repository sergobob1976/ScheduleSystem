<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Schedule.Maui.ViewModels"
             xmlns:models="clr-namespace:Schedule.Maui.Models"
             x:Class="Schedule.Maui.Views.StudentPage"
             x:DataType="viewmodels:StudentViewModel" 
             Title="Розклад занять коледжу">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Border StrokeThickness="0" BackgroundColor="#F0F2F5" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="10" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Дата" FontSize="12" TextColor="Gray"/>
                            <DatePicker Date="{Binding SelectedDate}" Format="dd.MM.yyyy" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Група" FontSize="12" TextColor="Gray"/>
                            <Picker ItemsSource="{Binding Groups}" 
                                    SelectedItem="{Binding SelectedGroup}" 
                                    />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Викладач" FontSize="12" TextColor="Gray"/>
                            <Picker ItemsSource="{Binding Teachers}" 
                                    SelectedItem="{Binding SelectedTeacher}" 
                                    />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Аудиторія" FontSize="12" TextColor="Gray"/>
                            <Picker ItemsSource="{Binding ClassRooms}" 
                                    SelectedItem="{Binding SelectedClassRoom}" 
                                    />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Border Grid.Row="1" Stroke="#512BD4" StrokeThickness="1" Padding="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="{Binding UserStatus}" VerticalOptions="Center" />
                <Button Text="Вхід" Command="{Binding LoginCommand}" HeightRequest="35" Padding="10,0" FontSize="12"/>
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="2" ItemsSource="{Binding VisibleLessons}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RealLesson">
                    <Border Margin="0,0,0,10" Padding="15" StrokeThickness="0.5" Stroke="#D0D0D0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" BackgroundColor="#512BD4" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="{Binding LessonPosition}" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Discipline}" FontAttributes="Bold" FontSize="16"/>
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="👨‍🏫" FontSize="12"/>
                                    <Label Text="{Binding Teacher}" TextColor="#404040" FontSize="14"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="📍" FontSize="12"/>
                                    <Label Text="{Binding ClassRoom}" TextColor="Gray" FontSize="14"/>
                                    <Label Text="{Binding Group, StringFormat='[{0}]'}" TextColor="#512BD4" FontSize="12" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>