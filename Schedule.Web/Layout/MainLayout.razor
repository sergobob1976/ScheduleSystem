@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="container-fluid">
    <div class="row">
        <div class="col-md-3 col-lg-2 bg-dark p-3 text-white sidebar-panel">
            <h5 class="text-center mb-4 border-bottom pb-2">
                📅 Розклад ЧКФКЕП
            </h5>

            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white" href="" Match="NavLinkMatch.All">
                        🏠 Головна
                    </NavLink>
                </li>

                <li class="nav-item mb-1"><NavLink class="nav-link text-white" href="base-schedule">🗓️ Базовий розклад</NavLink></li>
                <li class="nav-item mb-2"><NavLink class="nav-link text-white" href="schedule">📅 Реальний розклад</NavLink></li>

                <li class="nav-item mb-2">
                    <button type="button" class="menu-section-button" @onclick="() => referencesExpanded = !referencesExpanded">
                        <span>Довідники</span><span aria-hidden="true">@(referencesExpanded ? "▾" : "▸")</span>
                    </button>
                </li>
                @if (referencesExpanded)
                {
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="semesters"><span class="menu-icon">📆</span><span class="menu-label">Семестри</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="classrooms"><span class="menu-icon">🏫</span><span class="menu-label">Аудиторії</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="groups"><span class="menu-icon">🎒</span><span class="menu-label">Групи</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="specialties"><span class="menu-icon">🎓</span><span class="menu-label">Спеціальності</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="group-specialties"><span class="menu-icon">🔗</span><span class="menu-label">Групи та спеціальності</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="disciplines"><span class="menu-icon">📚</span><span class="menu-label">Дисципліни</span></NavLink></li>
                    <li class="nav-item mb-2 ms-2"><NavLink class="nav-link text-white menu-child-link" href="teachers"><span class="menu-icon">👨‍🏫</span><span class="menu-label">Викладачі</span></NavLink></li>
                }

                <li class="nav-item mb-2">
                    <button type="button" class="menu-section-button" @onclick="() => workloadExpanded = !workloadExpanded">
                        <span>Навчальне навантаження</span><span aria-hidden="true">@(workloadExpanded ? "▾" : "▸")</span>
                    </button>
                </li>
                @if (workloadExpanded)
                {
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="group-disciplines"><span class="menu-icon">📖</span><span class="menu-label">Навчальні плани груп</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="teacher-semester-loads"><span class="menu-icon">📊</span><span class="menu-label">Навантаження викладачів</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="teacher-discipline-loads"><span class="menu-icon">📚</span><span class="menu-label">Навантаження за дисциплінами</span></NavLink></li>
                    <li class="nav-item mb-1 ms-2"><NavLink class="nav-link text-white menu-child-link" href="teaching-assignments"><span class="menu-icon">🧑‍🏫</span><span class="menu-label">Призначення викладачів</span></NavLink></li>
                    <li class="nav-item mb-2 ms-2"><NavLink class="nav-link text-white menu-child-link" href="workload-overview"><span class="menu-icon">📈</span><span class="menu-label">Контроль навантаження</span></NavLink></li>
                }
            </ul>
        </div>

        <div class="col-md-9 col-lg-10 p-4 bg-light min-vh-100">
            @Body
        </div>
    </div>
</div>

@code {
    private bool referencesExpanded;
    private bool workloadExpanded;

    protected override void OnInitialized()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        referencesExpanded = path is "semesters" or "classrooms" or "groups" or "specialties" or "group-specialties" or "disciplines" or "teachers";
        workloadExpanded = path is "group-disciplines" or "teacher-semester-loads" or "teacher-discipline-loads" or "teaching-assignments" or "workload-overview";
    }
}

<style>
    .sidebar-panel {
        min-height: 100vh;
    }

    .nav-link.active {
        background-color: #0d6efd !important;
        color: white !important;
    }

    .nav-link:hover:not(.active) {
        background-color: #343a40;
    }

    .menu-section-button {
        align-items: center;
        background: transparent;
        border: 0;
        border-bottom: 1px solid #495057;
        color: #adb5bd;
        display: flex;
        font-size: .78rem;
        font-weight: 600;
        justify-content: space-between;
        letter-spacing: .04em;
        padding: .55rem .5rem;
        text-align: left;
        text-transform: uppercase;
        width: 100%;
    }

    .menu-section-button:hover {
        background-color: #343a40;
        color: white;
    }

    .menu-child-link {
        align-items: flex-start;
        display: flex;
    }

    .menu-icon {
        flex: 0 0 1.75rem;
        line-height: 1.5;
    }

    .menu-label {
        line-height: 1.5;
        min-width: 0;
    }

    @@media (min-width: 768px) {
        .sidebar-panel {
            height: 100vh;
            overflow-y: auto;
            position: sticky;
            top: 0;
        }
    }
</style>
