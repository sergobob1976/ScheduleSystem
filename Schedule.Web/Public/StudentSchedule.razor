@page "/student-schedule"
@layout StudentLayout
@using Schedule.Core.DTOs
@using Schedule.Core.Enums
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Розклад для студентів — ЧКФКЕП</PageTitle>

<h1 class="h3 mb-1">Розклад для студентів</h1>
<p class="text-muted mb-4">Оберіть групу та календарний тиждень.</p>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label class="form-label fw-bold">Семестр</label>
                <select class="form-select" disabled="@isLoadingOptions" @bind="semesterId" @bind:after="ChangeSemester">
                    @foreach (var semester in options.Semesters)
                    {
                        <option value="@semester.Id">@semester.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-3">
                <label class="form-label fw-bold">Група</label>
                <select class="form-select" disabled="@(isLoadingOptions || SelectedSemester is null)" @bind="groupId" @bind:after="ChangeGroup">
                    <option value="0">Оберіть групу</option>
                    @foreach (var group in SelectedSemester?.Groups ?? [])
                    {
                        <option value="@group.Id">@group.Name</option>
                    }
                </select>
            </div>
            <div class="col-lg-5">
                <label class="form-label fw-bold">Календарний тиждень</label>
                <select class="form-select" disabled="@(isLoadingOptions || SelectedSemester is null)" @bind="weekStart" @bind:after="LoadSchedule">
                    @foreach (var week in SelectedSemester?.Weeks ?? [])
                    {
                        <option value="@week.WeekStartDate.ToString("yyyy-MM-dd")">@week.ActiveStartDate.ToString("dd.MM")–@week.ActiveEndDate.ToString("dd.MM.yyyy")</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoadingOptions || isLoadingSchedule)
{
    <div class="text-center text-muted py-5"><div class="spinner-border text-primary mb-3"></div><div>Завантаження розкладу…</div></div>
}
else if (groupId <= 0)
{
    <div class="card border-0 shadow-sm"><div class="card-body text-center text-muted py-5">Оберіть свою навчальну групу.</div></div>
}
else if (lessons.Count == 0)
{
    <div class="card border-0 shadow-sm"><div class="card-body text-center text-muted py-5">На обраний тиждень занять немає.</div></div>
}
else
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">@SelectedGroupName · @SelectedWeekCaption</h2>
    </div>

    <div class="card shadow-sm d-none d-lg-block">
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0 schedule-grid student-schedule-grid">
                <thead><tr><th class="text-center table-light">Пара</th>
                    @foreach (var date in DisplayedDates)
                    {
                        <th class="student-day-header text-center"><div>@GetDayName(date)</div><div class="small fw-normal">@date.ToString("dd.MM.yyyy")</div></th>
                    }
                </tr></thead>
                <tbody>
                    @for (var position = 1; position <= 8; position++)
                    {
                        var currentPosition = position;
                        <tr><th class="text-center table-light">@currentPosition</th>
                            @foreach (var date in DisplayedDates)
                            {
                                var lesson = GetLesson(date, currentPosition);
                                <td class="schedule-cell student-schedule-cell">
                                    @if (lesson is not null)
                                    {
                                        <StudentLessonCard Lesson="lesson" />
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-lg-none">
        @foreach (var date in DisplayedDates)
        {
            var dayLessons = lessons.Where(item => item.LessonDate.Date == date.Date).OrderBy(item => item.LessonPosition).ToList();
            <section class="card shadow-sm mb-3 overflow-hidden">
                <div class="student-mobile-day-header"><strong>@GetDayName(date)</strong><span>@date.ToString("dd.MM.yyyy")</span></div>
                <div class="card-body p-2">
                    @if (dayLessons.Count == 0)
                    {
                        <div class="text-muted text-center py-3">Занять немає.</div>
                    }
                    else
                    {
                        @foreach (var lesson in dayLessons)
                        {
                            <div class="student-mobile-lesson @(lesson.Status == RealLessonStatus.Cancelled ? "student-lesson-cancelled" : "")">
                                <div class="student-mobile-position">@lesson.LessonPosition пара</div>
                                <StudentLessonCard Lesson="lesson" />
                            </div>
                        }
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    private StudentScheduleOptionsResponse options = new();
    private const string SavedGroupKey = "scheduleSystem.studentGroupId";
    private List<StudentScheduleLessonResponse> lessons = [];
    private int semesterId;
    private int groupId;
    private string weekStart = "";
    private bool isLoadingOptions;
    private bool isLoadingSchedule;
    private string errorMessage = "";

    private StudentScheduleSemesterOption? SelectedSemester => options.Semesters.FirstOrDefault(item => item.Id == semesterId);
    private StudentScheduleWeekOption? SelectedWeek => SelectedSemester?.Weeks.FirstOrDefault(item => item.WeekStartDate.ToString("yyyy-MM-dd") == weekStart);
    private string SelectedGroupName => SelectedSemester?.Groups.FirstOrDefault(item => item.Id == groupId)?.Name ?? "Група";
    private string SelectedWeekCaption => SelectedWeek is null ? "" : $"{SelectedWeek.ActiveStartDate:dd.MM}–{SelectedWeek.ActiveEndDate:dd.MM.yyyy}";
    private IEnumerable<DateTime> DisplayedDates => SelectedWeek is null
        ? []
        : Enumerable.Range(0, (SelectedWeek.ActiveEndDate.Date - SelectedWeek.ActiveStartDate.Date).Days + 1)
            .Select(offset => SelectedWeek.ActiveStartDate.Date.AddDays(offset));

    protected override async Task OnInitializedAsync()
    {
        isLoadingOptions = true;
        try
        {
            options = await Http.GetFromJsonAsync<StudentScheduleOptionsResponse>("api/student-schedule/options") ?? new();
            SelectDefaultSemesterAndWeek();
            await RestoreSavedGroup();
            if (groupId > 0)
            {
                await LoadSchedule();
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося завантажити параметри розкладу. Повторіть спробу пізніше.";
        }
        finally
        {
            isLoadingOptions = false;
        }
    }

    private async Task ChangeSemester()
    {
        lessons = [];
        errorMessage = "";
        SelectDefaultWeek();
        ApplySavedGroup();
        if (groupId > 0)
        {
            await LoadSchedule();
        }
    }

    private async Task ChangeGroup()
    {
        savedGroupId = groupId;
        try
        {
            if (groupId > 0)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", SavedGroupKey, groupId.ToString());
            }
            else
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", SavedGroupKey);
            }
        }
        catch (JSException)
        {
        }

        await LoadSchedule();
    }

    private void SelectDefaultSemesterAndWeek()
    {
        var today = DateTime.Today;
        var semester = options.Semesters.FirstOrDefault(item => item.StartDate.Date <= today && item.EndDate.Date >= today)
            ?? options.Semesters.Where(item => item.StartDate.Date > today).OrderBy(item => item.StartDate).FirstOrDefault()
            ?? options.Semesters.OrderByDescending(item => item.EndDate).FirstOrDefault();
        semesterId = semester?.Id ?? 0;
        SelectDefaultWeek();
    }

    private void SelectDefaultWeek()
    {
        var today = DateTime.Today;
        var week = SelectedSemester?.Weeks.FirstOrDefault(item => item.ActiveStartDate.Date <= today && item.ActiveEndDate.Date >= today)
            ?? SelectedSemester?.Weeks.Where(item => item.ActiveStartDate.Date > today).OrderBy(item => item.ActiveStartDate).FirstOrDefault()
            ?? SelectedSemester?.Weeks.OrderByDescending(item => item.ActiveEndDate).FirstOrDefault();
        weekStart = week?.WeekStartDate.ToString("yyyy-MM-dd") ?? "";
    }

    private int savedGroupId;

    private async Task RestoreSavedGroup()
    {
        try
        {
            var savedValue = await JS.InvokeAsync<string?>("localStorage.getItem", SavedGroupKey);
            int.TryParse(savedValue, out savedGroupId);
        }
        catch (JSException)
        {
            savedGroupId = 0;
        }

        ApplySavedGroup();
    }

    private void ApplySavedGroup()
    {
        groupId = SelectedSemester?.Groups.Any(item => item.Id == savedGroupId) == true
            ? savedGroupId
            : 0;
    }

    private async Task LoadSchedule()
    {
        lessons = [];
        errorMessage = "";
        if (semesterId <= 0 || groupId <= 0 || string.IsNullOrWhiteSpace(weekStart)) return;
        isLoadingSchedule = true;
        try
        {
            lessons = await Http.GetFromJsonAsync<List<StudentScheduleLessonResponse>>(
                $"api/student-schedule/semester/{semesterId}/group/{groupId}/week/{weekStart}") ?? [];
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося завантажити розклад. Повторіть спробу пізніше.";
        }
        finally
        {
            isLoadingSchedule = false;
        }
    }

    private StudentScheduleLessonResponse? GetLesson(DateTime date, int position) =>
        lessons.FirstOrDefault(item => item.LessonDate.Date == date.Date && item.LessonPosition == position);

    private static string GetDayName(DateTime date) => date.DayOfWeek switch
    {
        DayOfWeek.Monday => "Понеділок", DayOfWeek.Tuesday => "Вівторок",
        DayOfWeek.Wednesday => "Середа", DayOfWeek.Thursday => "Четвер",
        DayOfWeek.Friday => "П’ятниця", DayOfWeek.Saturday => "Субота",
        DayOfWeek.Sunday => "Неділя", _ => "—"
    };
}
