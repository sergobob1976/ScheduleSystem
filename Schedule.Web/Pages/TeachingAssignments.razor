@page "/teaching-assignments"
@using System.ComponentModel
@using System.Net
@using System.Net.Http.Json
@using System.Reflection
@using Schedule.Core.Enums
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">🧑‍🏫 Призначення викладачів</h3>

<p class="text-muted mb-4">
    Тут викладачі призначаються на дисципліни конкретних груп
    за видами занять. Система контролює години групи та
    навантаження викладача.
</p>

<div class="row g-4">
    <div class="crud-form-column">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування призначення"
                        : "Нове призначення")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Семестр
                    </label>

                    <select class="form-select"
                            value="@selectedSemesterId"
                            @onchange="OnSemesterChanged">
                        <option value="0">
                            -- Оберіть семестр --
                        </option>

                        @foreach (var semester in semesters ?? [])
                        {
                            <option value="@semester.Id">
                                @semester.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Група
                    </label>

                    <select class="form-select"
                            value="@selectedGroupId"
                            @onchange="OnGroupChanged"
                            disabled="@(selectedSemesterId <= 0)">
                        <option value="0">
                            -- Оберіть групу --
                        </option>

                        @foreach (var group in AvailableGroups)
                        {
                            <option value="@group.Id">
                                @group.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Дисципліна групи
                    </label>

                    <select class="form-select"
                            value="@form.GroupDisciplineId"
                            @onchange="OnGroupDisciplineChanged"
                            disabled="@(selectedGroupId <= 0)">
                        <option value="0">
                            -- Оберіть дисципліну --
                        </option>

                        @foreach (var item in AvailableGroupDisciplines)
                        {
                            <option value="@item.Id">
                                @GetGroupDisciplineText(item)
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Вид заняття
                    </label>

                    <select class="form-select"
                            value="@((int)form.LessonType)"
                            @onchange="OnLessonTypeChanged"
                            disabled="@(form.GroupDisciplineId <= 0)">
                        <option value="0">
                            -- Оберіть вид заняття --
                        </option>

                        @foreach (var lessonType in LessonTypes)
                        {
                            <option value="@((int)lessonType)">
                                @GetLessonTypeName(lessonType)
                            </option>
                        }
                    </select>
                </div>

                @if (SelectedGroupDiscipline != null &&
                     IsLessonTypeSelected)
                {
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <h6 class="mb-3">
                                Години групи
                            </h6>

                            <div class="row text-center g-2">
                                <div class="col-4">
                                    <div class="small text-muted">
                                        План
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @SelectedGroupPlannedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Призначено
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @GroupAlreadyAssignedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Залишок
                                    </div>

                                    <div class="fw-bold fs-5 @GetRemainingCssClass(GroupRemainingHours)">
                                        @GroupRemainingHours
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Викладач
                    </label>

                    <select class="form-select"
                            value="@form.TeacherId"
                            @onchange="OnTeacherChanged"
                            disabled="@(!IsLessonTypeSelected)">
                        <option value="0">
                            -- Оберіть викладача --
                        </option>

                        @foreach (var teacher in AvailableTeachers)
                        {
                            <option value="@teacher.Id">
                                @teacher.Name
                            </option>
                        }
                    </select>

                    @if (IsLessonTypeSelected &&
                         !AvailableTeachers.Any())
                    {
                        <div class="form-text text-danger">
                            Для цієї дисципліни в обраному семестрі
                            ще не задано навантаження жодному викладачу.
                        </div>
                    }
                </div>

                @if (SelectedTeacherDisciplineLoad != null)
                {
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <h6 class="mb-3">
                                Навантаження викладача
                            </h6>

                            <div class="row text-center g-2">
                                <div class="col-4">
                                    <div class="small text-muted">
                                        План із дисципліни
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @SelectedTeacherDisciplineLoad.PlannedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Уже призначено
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @TeacherAlreadyAssignedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Залишок
                                    </div>

                                    <div class="fw-bold fs-5 @GetRemainingCssClass(TeacherRemainingHours)">
                                        @TeacherRemainingHours
                                    </div>
                                </div>
                            </div>

                            @if (SelectedTeacherSemesterLoad != null)
                            {
                                <hr />

                                <div class="d-flex justify-content-between">
                                    <span>
                                        Загальний план на семестр:
                                    </span>

                                    <strong>
                                        @SelectedTeacherSemesterLoad.PlannedHours год.
                                    </strong>
                                </div>

                                <div class="d-flex justify-content-between">
                                    <span>
                                        Усього призначено:
                                    </span>

                                    <strong>
                                        @TeacherSemesterAssignedHours год.
                                    </strong>
                                </div>

                                <div class="d-flex justify-content-between">
                                    <span>
                                        Загальний залишок:
                                    </span>

                                    <strong class="@GetRemainingCssClass(TeacherSemesterRemainingHours)">
                                        @TeacherSemesterRemainingHours год.
                                    </strong>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Призначити годин
                    </label>

                    <div class="input-group">
                        <input type="number"
                               class="form-control"
                               min="1"
                               @bind="form.AssignedHours" />

                        <span class="input-group-text">
                            год.
                        </span>
                    </div>
                </div>

                @if (CanShowResultPreview)
                {
                    int groupAfterSaving =
                        GroupAlreadyAssignedHours +
                        form.AssignedHours;

                    int teacherAfterSaving =
                        TeacherAlreadyAssignedHours +
                        form.AssignedHours;

                    int groupRemainingAfterSaving =
                        SelectedGroupPlannedHours -
                        groupAfterSaving;

                    int teacherRemainingAfterSaving =
                        SelectedTeacherDisciplineLoad!.PlannedHours -
                        teacherAfterSaving;

                    <div class="alert @(groupRemainingAfterSaving < 0 ||
                                                                 teacherRemainingAfterSaving < 0
                                                                     ? "alert-danger"
                                                                     : "alert-info")">
                        <div>
                            У групи після збереження залишиться:
                            <strong>@groupRemainingAfterSaving год.</strong>
                        </div>

                        <div>
                            У викладача з дисципліни залишиться:
                            <strong>@teacherRemainingAfterSaving год.</strong>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveAssignment">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Створити призначення")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="crud-data-column">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Наявні призначення
                </h5>

                <span class="badge bg-primary">
                    Усього: @FilteredAssignments.Count()
                </span>
            </div>

            <div class="card-body border-bottom">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">
                            Семестр
                        </label>

                        <select class="form-select"
                                @bind="filterSemesterId">
                            <option value="0">
                                Усі семестри
                            </option>

                            @foreach (var semester in semesters ?? [])
                            {
                                <option value="@semester.Id">
                                    @semester.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold">
                            Група
                        </label>

                        <select class="form-select"
                                @bind="filterGroupId">
                            <option value="0">
                                Усі групи
                            </option>

                            @foreach (var group in groups ?? [])
                            {
                                <option value="@group.Id">
                                    @group.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold">
                            Викладач
                        </label>

                        <select class="form-select"
                                @bind="filterTeacherId">
                            <option value="0">
                                Усі викладачі
                            </option>

                            @foreach (var teacher in teachers ?? [])
                            {
                                <option value="@teacher.Id">
                                    @teacher.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження призначень...
                    </div>
                }
                else if (!FilteredAssignments.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Призначень за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Семестр</th>
                                    <th>Група</th>
                                    <th>Дисципліна</th>
                                    <th>Вид</th>
                                    <th>Викладач</th>
                                    <th class="text-center">Години</th>
                                    <th class="text-center">Дії</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredAssignments)
                                {
                                    <tr>
                                        <td>
                                            @GetAssignmentSemesterName(item)
                                        </td>

                                        <td class="fw-bold">
                                            @GetAssignmentGroupName(item)
                                        </td>

                                        <td>
                                            @GetAssignmentDisciplineName(item)
                                        </td>

                                        <td>
                                            <span class="badge bg-secondary">
                                                @GetLessonTypeName(
                                                    item.LessonType)
                                            </span>
                                        </td>

                                        <td>
                                            @(item.Teacher?.Name
                                                ?? GetTeacherName(
                                                    item.TeacherId))
                                        </td>

                                        <td class="text-center">
                                            <span class="badge bg-primary fs-6">
                                                @item.AssignedHours
                                            </span>
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(item)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == item.Id)"
                                                        @onclick="() => DeleteAssignment(item.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Semester>? semesters;
    private List<Group>? groups;
    private List<Discipline>? disciplines;
    private List<Teacher>? teachers;

    private List<GroupDiscipline>? groupDisciplines;
    private List<TeacherSemesterLoad>? teacherSemesterLoads;
    private List<TeacherDisciplineLoad>? teacherDisciplineLoads;
    private List<TeachingAssignment>? assignments;

    private TeachingAssignment form =
        CreateEmptyForm();

    private int selectedSemesterId;
    private int selectedGroupId;

    private int filterSemesterId;
    private int filterGroupId;
    private int filterTeacherId;

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private static IEnumerable<LessonType> LessonTypes =>
        Enum.GetValues<LessonType>();

    private bool IsLessonTypeSelected =>
        Enum.IsDefined(
            typeof(LessonType),
            form.LessonType);

    private IEnumerable<Group> AvailableGroups
    {
        get
        {
            if (selectedSemesterId <= 0)
            {
                return [];
            }

            var groupIds =
                (groupDisciplines ?? [])
                .Where(
                    x => x.SemesterId ==
                         selectedSemesterId)
                .Select(x => x.GroupId)
                .Distinct()
                .ToHashSet();

            return (groups ?? [])
                .Where(x => groupIds.Contains(x.Id))
                .OrderBy(x => x.Name);
        }
    }

    private IEnumerable<GroupDiscipline>
        AvailableGroupDisciplines
    {
        get
        {
            if (selectedSemesterId <= 0 ||
                selectedGroupId <= 0)
            {
                return [];
            }

            return (groupDisciplines ?? [])
                .Where(
                    x =>
                        x.SemesterId ==
                        selectedSemesterId
                        &&
                        x.GroupId ==
                        selectedGroupId)
                .OrderBy(
                    x => x.Discipline?.Name
                         ?? GetDisciplineName(
                             x.DisciplineId));
        }
    }

    private GroupDiscipline? SelectedGroupDiscipline =>
        groupDisciplines?.FirstOrDefault(
            x => x.Id == form.GroupDisciplineId);

    private IEnumerable<Teacher> AvailableTeachers
    {
        get
        {
            if (SelectedGroupDiscipline == null)
            {
                return [];
            }

            var teacherIds =
                (teacherDisciplineLoads ?? [])
                .Where(
                    x =>
                    {
                        var semesterLoad =
                            GetTeacherSemesterLoad(
                                x.TeacherSemesterLoadId);

                        return semesterLoad != null
                               &&
                               semesterLoad.SemesterId ==
                               SelectedGroupDiscipline.SemesterId
                               &&
                               x.DisciplineId ==
                               SelectedGroupDiscipline.DisciplineId;
                    })
                .Select(
                    x =>
                        GetTeacherSemesterLoad(
                            x.TeacherSemesterLoadId)!
                            .TeacherId)
                .Distinct()
                .ToHashSet();

            return (teachers ?? [])
                .Where(x => teacherIds.Contains(x.Id))
                .OrderBy(x => x.Name);
        }
    }

    private TeacherSemesterLoad?
        SelectedTeacherSemesterLoad
    {
        get
        {
            if (SelectedGroupDiscipline == null ||
                form.TeacherId <= 0)
            {
                return null;
            }

            return teacherSemesterLoads?
                .FirstOrDefault(
                    x =>
                        x.TeacherId == form.TeacherId
                        &&
                        x.SemesterId ==
                        SelectedGroupDiscipline.SemesterId);
        }
    }

    private TeacherDisciplineLoad?
        SelectedTeacherDisciplineLoad
    {
        get
        {
            if (SelectedTeacherSemesterLoad == null ||
                SelectedGroupDiscipline == null)
            {
                return null;
            }

            return teacherDisciplineLoads?
                .FirstOrDefault(
                    x =>
                        x.TeacherSemesterLoadId ==
                        SelectedTeacherSemesterLoad.Id
                        &&
                        x.DisciplineId ==
                        SelectedGroupDiscipline.DisciplineId);
        }
    }

    private int SelectedGroupPlannedHours =>
        SelectedGroupDiscipline == null
            ? 0
            : GetPlannedHours(
                SelectedGroupDiscipline,
                form.LessonType);

    private int GroupAlreadyAssignedHours =>
        (assignments ?? [])
        .Where(
            x =>
                x.GroupDisciplineId ==
                form.GroupDisciplineId
                &&
                x.LessonType ==
                form.LessonType
                &&
                (
                    !editingId.HasValue
                    ||
                    x.Id != editingId.Value
                ))
        .Sum(x => x.AssignedHours);

    private int GroupRemainingHours =>
        SelectedGroupPlannedHours -
        GroupAlreadyAssignedHours;

    private int TeacherAlreadyAssignedHours
    {
        get
        {
            if (SelectedGroupDiscipline == null ||
                form.TeacherId <= 0)
            {
                return 0;
            }

            return (assignments ?? [])
                .Where(
                    x =>
                    {
                        if (editingId.HasValue &&
                            x.Id == editingId.Value)
                        {
                            return false;
                        }

                        var groupDiscipline =
                            GetGroupDiscipline(
                                x.GroupDisciplineId);

                        return x.TeacherId ==
                               form.TeacherId
                               &&
                               groupDiscipline != null
                               &&
                               groupDiscipline.SemesterId ==
                               SelectedGroupDiscipline.SemesterId
                               &&
                               groupDiscipline.DisciplineId ==
                               SelectedGroupDiscipline.DisciplineId;
                    })
                .Sum(x => x.AssignedHours);
        }
    }

    private int TeacherRemainingHours =>
        SelectedTeacherDisciplineLoad == null
            ? 0
            : SelectedTeacherDisciplineLoad.PlannedHours -
              TeacherAlreadyAssignedHours;

    private int TeacherSemesterAssignedHours
    {
        get
        {
            if (SelectedTeacherSemesterLoad == null)
            {
                return 0;
            }

            return (assignments ?? [])
                .Where(
                    x =>
                    {
                        if (editingId.HasValue &&
                            x.Id == editingId.Value)
                        {
                            return false;
                        }

                        var groupDiscipline =
                            GetGroupDiscipline(
                                x.GroupDisciplineId);

                        return x.TeacherId ==
                               SelectedTeacherSemesterLoad.TeacherId
                               &&
                               groupDiscipline?.SemesterId ==
                               SelectedTeacherSemesterLoad.SemesterId;
                    })
                .Sum(x => x.AssignedHours);
        }
    }

    private int TeacherSemesterRemainingHours =>
        SelectedTeacherSemesterLoad == null
            ? 0
            : SelectedTeacherSemesterLoad.PlannedHours -
              TeacherSemesterAssignedHours;

    private bool CanShowResultPreview =>
        SelectedGroupDiscipline != null
        &&
        SelectedTeacherDisciplineLoad != null
        &&
        IsLessonTypeSelected
        &&
        form.AssignedHours > 0;

    private IEnumerable<TeachingAssignment>
        FilteredAssignments
    {
        get
        {
            IEnumerable<TeachingAssignment> result =
                assignments ?? [];

            if (filterSemesterId > 0)
            {
                result = result.Where(
                    x =>
                        GetGroupDiscipline(
                            x.GroupDisciplineId)?
                        .SemesterId ==
                        filterSemesterId);
            }

            if (filterGroupId > 0)
            {
                result = result.Where(
                    x =>
                        GetGroupDiscipline(
                            x.GroupDisciplineId)?
                        .GroupId ==
                        filterGroupId);
            }

            if (filterTeacherId > 0)
            {
                result = result.Where(
                    x => x.TeacherId ==
                         filterTeacherId);
            }

            return result
                .OrderByDescending(
                    x =>
                        GetAssignmentSemesterStartDate(x))
                .ThenBy(
                    x => GetAssignmentGroupName(x))
                .ThenBy(
                    x => GetAssignmentDisciplineName(x))
                .ThenBy(x => x.LessonType)
                .ThenBy(
                    x =>
                        x.Teacher?.Name
                        ?? GetTeacherName(x.TeacherId));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var semestersTask =
                Http.GetFromJsonAsync<List<Semester>>(
                    "api/semesters");

            var groupsTask =
                Http.GetFromJsonAsync<List<Group>>(
                    "api/groups");

            var disciplinesTask =
                Http.GetFromJsonAsync<List<Discipline>>(
                    "api/disciplines");

            var teachersTask =
                Http.GetFromJsonAsync<List<Teacher>>(
                    "api/teachers");

            var groupDisciplinesTask =
                Http.GetFromJsonAsync<List<GroupDiscipline>>(
                    "api/groupdisciplines");

            var teacherSemesterLoadsTask =
                Http.GetFromJsonAsync<
                    List<TeacherSemesterLoad>>(
                    "api/teachersemesterloads");

            var teacherDisciplineLoadsTask =
                Http.GetFromJsonAsync<
                    List<TeacherDisciplineLoad>>(
                    "api/teacherdisciplineloads");

            var assignmentsTask =
                Http.GetFromJsonAsync<
                    List<TeachingAssignment>>(
                    "api/teachingassignments");

            await Task.WhenAll(
                semestersTask,
                groupsTask,
                disciplinesTask,
                teachersTask,
                groupDisciplinesTask,
                teacherSemesterLoadsTask,
                teacherDisciplineLoadsTask,
                assignmentsTask);

            semesters =
                semestersTask.Result ?? [];

            groups =
                groupsTask.Result ?? [];

            disciplines =
                disciplinesTask.Result ?? [];

            teachers =
                teachersTask.Result ?? [];

            groupDisciplines =
                groupDisciplinesTask.Result ?? [];

            teacherSemesterLoads =
                teacherSemesterLoadsTask.Result ?? [];

            teacherDisciplineLoads =
                teacherDisciplineLoadsTask.Result ?? [];

            assignments =
                assignmentsTask.Result ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSemesterChanged(
        ChangeEventArgs args)
    {
        selectedSemesterId =
            ParseInt(args.Value);

        selectedGroupId = 0;

        form.GroupDisciplineId = 0;
        form.TeacherId = 0;
        form.LessonType = 0;
        form.AssignedHours = 0;

        message = "";
    }

    private void OnGroupChanged(
        ChangeEventArgs args)
    {
        selectedGroupId =
            ParseInt(args.Value);

        form.GroupDisciplineId = 0;
        form.TeacherId = 0;
        form.LessonType = 0;
        form.AssignedHours = 0;

        message = "";
    }

    private void OnGroupDisciplineChanged(
        ChangeEventArgs args)
    {
        form.GroupDisciplineId =
            ParseInt(args.Value);

        form.TeacherId = 0;
        form.LessonType = 0;
        form.AssignedHours = 0;

        message = "";
    }

    private void OnLessonTypeChanged(
        ChangeEventArgs args)
    {
        int value = ParseInt(args.Value);

        form.LessonType =
            Enum.IsDefined(
                typeof(LessonType),
                value)
                ? (LessonType)value
                : 0;

        form.TeacherId = 0;
        form.AssignedHours = 0;

        message = "";
    }

    private void OnTeacherChanged(
        ChangeEventArgs args)
    {
        form.TeacherId =
            ParseInt(args.Value);

        form.AssignedHours = 0;

        message = "";
    }

    private async Task SaveAssignment()
    {
        if (form.GroupDisciplineId <= 0)
        {
            ShowError(
                "Потрібно обрати дисципліну групи.");

            return;
        }

        if (!IsLessonTypeSelected)
        {
            ShowError(
                "Потрібно обрати вид заняття.");

            return;
        }

        if (form.TeacherId <= 0)
        {
            ShowError(
                "Потрібно обрати викладача.");

            return;
        }

        if (form.AssignedHours <= 0)
        {
            ShowError(
                "Кількість годин має бути більшою за нуль.");

            return;
        }

        isSaving = true;

        try
        {
            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/teachingassignments/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/teachingassignments",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadAssignments();

                ShowSuccess(
                    wasEditing
                        ? "Призначення оновлено."
                        : "Викладача призначено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти призначення."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(
        TeachingAssignment item)
    {
        var groupDiscipline =
            GetGroupDiscipline(
                item.GroupDisciplineId);

        if (groupDiscipline == null)
        {
            ShowError(
                "Не вдалося знайти дисципліну групи.");

            return;
        }

        editingId = item.Id;

        selectedSemesterId =
            groupDiscipline.SemesterId;

        selectedGroupId =
            groupDiscipline.GroupId;

        form = new TeachingAssignment
        {
            Id = item.Id,
            GroupDisciplineId =
                item.GroupDisciplineId,
            TeacherId = item.TeacherId,
            LessonType = item.LessonType,
            AssignedHours = item.AssignedHours
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteAssignment(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/teachingassignments/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadAssignments();

                ShowSuccess(
                    "Призначення видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити призначення."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadAssignments()
    {
        assignments =
            await Http.GetFromJsonAsync<
                List<TeachingAssignment>>(
                "api/teachingassignments")
            ?? [];
    }

    private GroupDiscipline?
        GetGroupDiscipline(int id)
    {
        return groupDisciplines?
            .FirstOrDefault(x => x.Id == id);
    }

    private TeacherSemesterLoad?
        GetTeacherSemesterLoad(int id)
    {
        return teacherSemesterLoads?
            .FirstOrDefault(x => x.Id == id);
    }

    private string GetGroupDisciplineText(
        GroupDiscipline item)
    {
        string disciplineName =
            item.Discipline?.Name
            ?? GetDisciplineName(
                item.DisciplineId);

        return
            $"{disciplineName} — {item.TotalHours} год.";
    }

    private string GetAssignmentSemesterName(
        TeachingAssignment item)
    {
        var groupDiscipline =
            GetGroupDiscipline(
                item.GroupDisciplineId);

        return groupDiscipline?.Semester?.Name
            ?? semesters?
                .FirstOrDefault(
                    x => x.Id ==
                         groupDiscipline?.SemesterId)?
                .Name
            ?? "—";
    }

    private DateTime GetAssignmentSemesterStartDate(
        TeachingAssignment item)
    {
        var groupDiscipline =
            GetGroupDiscipline(
                item.GroupDisciplineId);

        return groupDiscipline?.Semester?.StartDate
            ?? semesters?
                .FirstOrDefault(
                    x => x.Id ==
                         groupDiscipline?.SemesterId)?
                .StartDate
            ?? DateTime.MinValue;
    }

    private string GetAssignmentGroupName(
        TeachingAssignment item)
    {
        var groupDiscipline =
            GetGroupDiscipline(
                item.GroupDisciplineId);

        return groupDiscipline?.Group?.Name
            ?? groups?
                .FirstOrDefault(
                    x => x.Id ==
                         groupDiscipline?.GroupId)?
                .Name
            ?? "—";
    }

    private string GetAssignmentDisciplineName(
        TeachingAssignment item)
    {
        var groupDiscipline =
            GetGroupDiscipline(
                item.GroupDisciplineId);

        return groupDiscipline?.Discipline?.Name
            ?? disciplines?
                .FirstOrDefault(
                    x => x.Id ==
                         groupDiscipline?.DisciplineId)?
                .Name
            ?? "—";
    }

    private string GetDisciplineName(int id)
    {
        return disciplines?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private string GetTeacherName(int id)
    {
        return teachers?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private static int GetPlannedHours(
        GroupDiscipline groupDiscipline,
        LessonType lessonType)
    {
        return lessonType switch
        {
            LessonType.Lecture =>
                groupDiscipline.LectureHours,

            LessonType.Practical =>
                groupDiscipline.PracticalHours,

            LessonType.Laboratory =>
                groupDiscipline.LaboratoryHours,

            LessonType.Seminar =>
                groupDiscipline.SeminarHours,

            LessonType.Other =>
                groupDiscipline.OtherHours,

            _ => 0
        };
    }

    private static string GetLessonTypeName(
        LessonType lessonType)
    {
        var field =
            typeof(LessonType).GetField(
                lessonType.ToString());

        var description =
            field?.GetCustomAttribute<
                DescriptionAttribute>();

        return description?.Description
            ?? lessonType.ToString();
    }

    private static string GetRemainingCssClass(
        int remaining)
    {
        return remaining switch
        {
            < 0 => "text-danger",
            0 => "text-success",
            _ => "text-primary"
        };
    }

    private static int ParseInt(object? value)
    {
        return int.TryParse(
            value?.ToString(),
            out int result)
            ? result
            : 0;
    }

    private void ResetForm()
    {
        editingId = null;

        selectedSemesterId = 0;
        selectedGroupId = 0;

        form = CreateEmptyForm();
    }

    private static TeachingAssignment
        CreateEmptyForm()
    {
        return new TeachingAssignment
        {
            GroupDisciplineId = 0,
            TeacherId = 0,
            LessonType = 0,
            AssignedHours = 0
        };
    }

    private static async Task<string>
        ReadErrorMessage(
            HttpResponseMessage response,
            string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Таке призначення викладача вже існує.",

            HttpStatusCode.BadRequest =>
                "Перевірте години групи та навантаження викладача.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
