@page "/teacher-semester-loads"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">📊 Навантаження викладачів на семестр</h3>

<p class="text-muted mb-4">
    Тут задається загальна кількість годин, яку викладач
    повинен вичитати протягом обраного семестру.
</p>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування навантаження"
                        : "Нове навантаження")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Семестр
                    </label>

                    <select class="form-select"
                            @bind="form.SemesterId">
                        <option value="0">
                            -- Оберіть семестр --
                        </option>

                        @if (semesters != null)
                        {
                            @foreach (var semester in semesters)
                            {
                                <option value="@semester.Id">
                                    @semester.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Викладач
                    </label>

                    <select class="form-select"
                            @bind="form.TeacherId">
                        <option value="0">
                            -- Оберіть викладача --
                        </option>

                        @if (teachers != null)
                        {
                            @foreach (var teacher in teachers)
                            {
                                <option value="@teacher.Id">
                                    @teacher.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Загальне планове навантаження
                    </label>

                    <div class="input-group">
                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.PlannedHours" />

                        <span class="input-group-text">
                            год.
                        </span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveLoad">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати навантаження")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Планове навантаження
                </h5>

                <span class="badge bg-primary">
                    Усього записів: @FilteredLoads.Count()
                </span>
            </div>

            <div class="card-body border-bottom">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Семестр
                        </label>

                        <select class="form-select"
                                @bind="filterSemesterId">
                            <option value="0">
                                Усі семестри
                            </option>

                            @if (semesters != null)
                            {
                                @foreach (var semester in semesters)
                                {
                                    <option value="@semester.Id">
                                        @semester.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Пошук викладача
                        </label>

                        <input type="text"
                               class="form-control"
                               placeholder="Введіть ПІБ"
                               @bind="searchText"
                               @bind:event="oninput" />
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження навантаження...
                    </div>
                }
                else if (!FilteredLoads.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Записів за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>
                                        Семестр
                                    </th>

                                    <th>
                                        Викладач
                                    </th>

                                    <th>
                                        Посада
                                    </th>

                                    <th class="text-center">
                                        План, год.
                                    </th>

                                    <th class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredLoads)
                                {
                                    <tr>
                                        <td>
                                            @(item.Semester?.Name
                                                ?? GetSemesterName(
                                                    item.SemesterId))
                                        </td>

                                        <td class="fw-bold">
                                            @(item.Teacher?.Name
                                                ?? GetTeacherName(
                                                    item.TeacherId))
                                        </td>

                                        <td>
                                            @(item.Teacher?.Position
                                                ?? GetTeacherPosition(
                                                    item.TeacherId))
                                        </td>

                                        <td class="text-center">
                                            <span class="badge bg-primary fs-6">
                                                @item.PlannedHours
                                            </span>
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(item)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == item.Id)"
                                                        @onclick="() => DeleteLoad(item.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Semester>? semesters;
    private List<Teacher>? teachers;
    private List<TeacherSemesterLoad>? loads;

    private TeacherSemesterLoad form =
        CreateEmptyForm();

    private int filterSemesterId;
    private string searchText = "";

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<TeacherSemesterLoad> FilteredLoads
    {
        get
        {
            IEnumerable<TeacherSemesterLoad> result =
                loads ?? [];

            if (filterSemesterId > 0)
            {
                result = result.Where(
                    x => x.SemesterId ==
                         filterSemesterId);
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                string value =
                    searchText.Trim();

                result = result.Where(
                    x =>
                        GetTeacherName(x.TeacherId)
                            .Contains(
                                value,
                                StringComparison.OrdinalIgnoreCase));
            }

            return result
                .OrderByDescending(
                    x => x.Semester?.StartDate)
                .ThenBy(x => x.Teacher?.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var semestersTask =
                Http.GetFromJsonAsync<List<Semester>>(
                    "api/semesters");

            var teachersTask =
                Http.GetFromJsonAsync<List<Teacher>>(
                    "api/teachers");

            var loadsTask =
                Http.GetFromJsonAsync<List<TeacherSemesterLoad>>(
                    "api/teachersemesterloads");

            await Task.WhenAll(
                semestersTask,
                teachersTask,
                loadsTask);

            semesters =
                semestersTask.Result
                ?? [];

            teachers =
                teachersTask.Result
                ?? [];

            loads =
                loadsTask.Result
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveLoad()
    {
        if (form.SemesterId <= 0)
        {
            ShowError(
                "Потрібно обрати семестр.");

            return;
        }

        if (form.TeacherId <= 0)
        {
            ShowError(
                "Потрібно обрати викладача.");

            return;
        }

        if (form.PlannedHours < 0)
        {
            ShowError(
                "Планова кількість годин не може бути від’ємною.");

            return;
        }

        isSaving = true;

        try
        {
            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/teachersemesterloads/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/teachersemesterloads",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadLoads();

                ShowSuccess(
                    wasEditing
                        ? "Навантаження оновлено."
                        : "Навантаження додано.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти навантаження."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(
        TeacherSemesterLoad item)
    {
        editingId = item.Id;

        form = new TeacherSemesterLoad
        {
            Id = item.Id,
            SemesterId = item.SemesterId,
            TeacherId = item.TeacherId,
            PlannedHours = item.PlannedHours
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteLoad(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/teachersemesterloads/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadLoads();

                ShowSuccess(
                    "Навантаження видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити навантаження."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadLoads()
    {
        loads =
            await Http.GetFromJsonAsync<
                List<TeacherSemesterLoad>>(
                "api/teachersemesterloads")
            ?? [];
    }

    private string GetSemesterName(int id)
    {
        return semesters?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private string GetTeacherName(int id)
    {
        return teachers?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private string GetTeacherPosition(int id)
    {
        var position =
            teachers?
                .FirstOrDefault(x => x.Id == id)?
                .Position;

        return string.IsNullOrWhiteSpace(position)
            ? "—"
            : position;
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static TeacherSemesterLoad CreateEmptyForm()
    {
        return new TeacherSemesterLoad
        {
            SemesterId = 0,
            TeacherId = 0,
            PlannedHours = 0
        };
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Для цього викладача в обраному семестрі " +
                "навантаження вже існує.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність вибраних даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}