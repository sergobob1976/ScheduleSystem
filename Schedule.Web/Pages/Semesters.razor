@page "/semesters"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-4">📆 Довідник семестрів</h3>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування семестру"
                        : "Новий семестр")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Назва семестру
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="Наприклад: Осінній 2026"
                           @bind="form.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Дата початку
                    </label>

                    <input type="date"
                           class="form-control"
                           @bind="form.StartDate"
                           @bind:format="yyyy-MM-dd" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Дата завершення
                    </label>

                    <input type="date"
                           class="form-control"
                           @bind="form.EndDate"
                           @bind:format="yyyy-MM-dd" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveSemester">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати семестр")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Список семестрів
                </h5>

                <span class="badge bg-primary">
                    Усього: @(semesters?.Count ?? 0)
                </span>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження семестрів...
                    </div>
                }
                else if (semesters == null ||
                         semesters.Count == 0)
                {
                    <div class="p-4 text-center text-muted">
                        Семестрів поки немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Назва</th>
                                    <th>Початок</th>
                                    <th>Завершення</th>
                                    <th>Тривалість</th>
                                    <th class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var semester in semesters)
                                {
                                    <tr>
                                        <td>@semester.Id</td>

                                        <td class="fw-bold">
                                            @semester.Name
                                        </td>

                                        <td>
                                            @semester.StartDate.ToString("dd.MM.yyyy")
                                        </td>

                                        <td>
                                            @semester.EndDate.ToString("dd.MM.yyyy")
                                        </td>

                                        <td>
                                            @GetDurationText(semester)
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(semester)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == semester.Id)"
                                                        @onclick="() => DeleteSemester(semester.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Semester>? semesters;

    private Semester form = CreateEmptyForm();

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadSemesters();
    }

    private async Task LoadSemesters()
    {
        isLoading = true;

        try
        {
            semesters =
                await Http.GetFromJsonAsync<List<Semester>>(
                    "api/semesters")
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSemester()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            ShowError(
                "Назва семестру не може бути порожньою.");

            return;
        }

        if (form.EndDate < form.StartDate)
        {
            ShowError(
                "Дата завершення не може бути раніше дати початку.");

            return;
        }

        isSaving = true;

        try
        {
            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/semesters/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/semesters",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                ShowSuccess(
                    editingId.HasValue
                        ? "Семестр оновлено."
                        : "Семестр додано.");

                ResetForm();

                await LoadSemesters();

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти семестр."));
        }
        catch (Exception ex)
        {
            ShowError($"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(Semester semester)
    {
        editingId = semester.Id;

        form = new Semester
        {
            Id = semester.Id,
            Name = semester.Name,
            StartDate = semester.StartDate,
            EndDate = semester.EndDate
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteSemester(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/semesters/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                ShowSuccess("Семестр видалено.");

                await LoadSemesters();

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити семестр."));
        }
        catch (Exception ex)
        {
            ShowError($"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static Semester CreateEmptyForm()
    {
        var today = DateTime.Today;

        return new Semester
        {
            Name = "",
            StartDate = today,
            EndDate = today.AddMonths(4)
        };
    }

    private static string GetDurationText(
        Semester semester)
    {
        int days =
            (semester.EndDate.Date -
             semester.StartDate.Date).Days + 1;

        return $"{days} дн.";
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
            // Використовуємо стандартне повідомлення.
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Операцію неможливо виконати через пов'язані дані.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність введених даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
