@page "/classrooms"
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-4">🏫 Довідник аудиторій</h3>

<div class="card mb-4 col-md-6 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Додати аудиторію</h5>

        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Назва аудиторії, напр. 205 або Лаб. 3"
                   @bind="newRoomName" />

            <button class="btn btn-primary" @onclick="CreateClassRoom">
                Додати
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-info mt-3 mb-0 py-2">@message</div>
        }
    </div>
</div>

@if (classRooms == null)
{
    <p><em>Завантаження аудиторій...</em></p>
}
else if (!classRooms.Any())
{
    <p class="text-muted">Аудиторій поки немає.</p>
}
else
{
    <div class="card shadow-sm col-md-8">
        <div class="card-header bg-dark text-white">
            Список аудиторій
        </div>

        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 15%">ID</th>
                    <th style="width: 65%">Назва</th>
                    <th style="width: 20%" class="text-center">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in classRooms)
                {
                    <tr>
                        <td>@room.Id</td>
                        <td>@room.Name</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteClassRoom(room.Id)">
                                Видалити
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ClassRoom>? classRooms;

    private string newRoomName = "";
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadClassRooms();
    }

    private async Task LoadClassRooms()
    {
        try
        {
            classRooms = await Http.GetFromJsonAsync<List<ClassRoom>>("api/classrooms");
        }
        catch (Exception ex)
        {
            message = $"Помилка завантаження: {ex.Message}";
        }
    }

    private async Task CreateClassRoom()
    {
        if (string.IsNullOrWhiteSpace(newRoomName))
        {
            message = "Назва аудиторії не може бути порожньою.";
            return;
        }

        var room = new ClassRoom
        {
            Name = newRoomName.Trim()
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/classrooms", room);

            if (response.IsSuccessStatusCode)
            {
                newRoomName = "";
                message = "Аудиторію додано.";
                await LoadClassRooms();
            }
            else
            {
                message = "Не вдалося додати аудиторію. Можливо, така аудиторія вже існує.";
            }
        }
        catch (Exception ex)
        {
            message = $"Помилка: {ex.Message}";
        }
    }

    private async Task DeleteClassRoom(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/classrooms/{id}");

            if (response.IsSuccessStatusCode)
            {
                message = "Аудиторію видалено.";
                await LoadClassRooms();
            }
            else
            {
                message = "Не вдалося видалити аудиторію. Можливо, вона використовується в розкладі.";
            }
        }
        catch (Exception ex)
        {
            message = $"Помилка: {ex.Message}";
        }
    }
}
