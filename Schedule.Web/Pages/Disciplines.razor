@page "/disciplines"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">📚 Довідник дисциплін</h3>

<p class="text-muted mb-4">
    Тут створюються назви дисциплін для спеціальностей.
    Семестр, група та навчальні години задаються окремо.
</p>

<div class="row g-4">
    <div class="crud-form-column">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування дисципліни"
                        : "Нова дисципліна")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Спеціальність
                    </label>

                    <select class="form-select"
                            @bind="form.SpecialtyId">
                        <option value="0">
                            -- Оберіть спеціальність --
                        </option>

                        @if (specialties != null)
                        {
                            @foreach (var specialty in specialties)
                            {
                                <option value="@specialty.Id">
                                    @specialty.Code — @specialty.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Назва дисципліни
                    </label>

                    <input type="text"
                           class="form-control"
                           maxlength="150"
                           placeholder="Наприклад: Бази даних"
                           @bind="form.Name" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveDiscipline">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати дисципліну")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="crud-data-column">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Список дисциплін
                </h5>

                <span class="badge bg-primary">
                    Усього: @FilteredDisciplines.Count()
                </span>
            </div>

            <div class="card-body border-bottom">
                <label class="form-label small fw-bold">
                    Фільтр за спеціальністю
                </label>

                <select class="form-select"
                        @bind="filterSpecialtyId">
                    <option value="0">
                        Усі спеціальності
                    </option>

                    @if (specialties != null)
                    {
                        @foreach (var specialty in specialties)
                        {
                            <option value="@specialty.Id">
                                @specialty.Code — @specialty.Name
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження дисциплін...
                    </div>
                }
                else if (!FilteredDisciplines.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Дисциплін за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 10%">
                                        ID
                                    </th>

                                    <th style="width: 35%">
                                        Спеціальність
                                    </th>

                                    <th>
                                        Дисципліна
                                    </th>

                                    <th style="width: 25%"
                                        class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var discipline in FilteredDisciplines)
                                {
                                    <tr>
                                        <td>
                                            @discipline.Id
                                        </td>

                                        <td>
                                            @if (discipline.Specialty != null)
                                            {
                                                <span class="badge bg-primary me-2">
                                                    @discipline.Specialty.Code
                                                </span>

                                                <span>
                                                    @discipline.Specialty.Name
                                                </span>
                                            }
                                            else
                                            {
                                                @GetSpecialtyText(
                                                    discipline.SpecialtyId)
                                            }
                                        </td>

                                        <td class="fw-bold">
                                            @discipline.Name
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(discipline)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == discipline.Id)"
                                                        @onclick="() => DeleteDiscipline(discipline.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Discipline>? disciplines;
    private List<Specialty>? specialties;

    private Discipline form = CreateEmptyForm();

    private int filterSpecialtyId;

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<Discipline> FilteredDisciplines
    {
        get
        {
            IEnumerable<Discipline> result =
                disciplines ?? [];

            if (filterSpecialtyId > 0)
            {
                result = result.Where(
                    x => x.SpecialtyId ==
                         filterSpecialtyId);
            }

            return result
                .OrderBy(x => x.Specialty?.Code)
                .ThenBy(x => x.Specialty?.Name)
                .ThenBy(x => x.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var specialtiesTask =
                Http.GetFromJsonAsync<List<Specialty>>(
                    "api/specialties");

            var disciplinesTask =
                Http.GetFromJsonAsync<List<Discipline>>(
                    "api/disciplines");

            await Task.WhenAll(
                specialtiesTask,
                disciplinesTask);

            specialties =
                specialtiesTask.Result
                ?? [];

            disciplines =
                disciplinesTask.Result
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveDiscipline()
    {
        if (form.SpecialtyId <= 0)
        {
            ShowError(
                "Потрібно обрати спеціальність.");

            return;
        }

        if (string.IsNullOrWhiteSpace(form.Name))
        {
            ShowError(
                "Назва дисципліни не може бути порожньою.");

            return;
        }

        isSaving = true;

        try
        {
            form.Name = form.Name.Trim();

            ClearHours(form);

            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/disciplines/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/disciplines",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadDisciplines();

                ShowSuccess(
                    wasEditing
                        ? "Дисципліну оновлено."
                        : "Дисципліну додано.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти дисципліну."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(
        Discipline discipline)
    {
        editingId = discipline.Id;

        form = new Discipline
        {
            Id = discipline.Id,
            SpecialtyId = discipline.SpecialtyId,
            Name = discipline.Name
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteDiscipline(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/disciplines/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadDisciplines();

                ShowSuccess(
                    "Дисципліну видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити дисципліну."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadDisciplines()
    {
        disciplines =
            await Http.GetFromJsonAsync<List<Discipline>>(
                "api/disciplines")
            ?? [];
    }

    private string GetSpecialtyText(
        int specialtyId)
    {
        var specialty =
            specialties?.FirstOrDefault(
                x => x.Id == specialtyId);

        return specialty == null
            ? $"ID {specialtyId}"
            : $"{specialty.Code} — {specialty.Name}";
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static Discipline CreateEmptyForm()
    {
        return new Discipline
        {
            SpecialtyId = 0,
            Name = ""
        };
    }

    private static void ClearHours(
        Discipline discipline)
    {
        discipline.TotalHours = null;
        discipline.LectureHours = null;
        discipline.PracticalHours = null;
        discipline.LaboratoryHours = null;
        discipline.SeminarHours = null;
        discipline.OtherHours = null;
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Така дисципліна вже існує або " +
                "використовується в інших даних.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність введених даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
