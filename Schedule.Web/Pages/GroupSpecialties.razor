@page "/group-specialties"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-4">🔗 Прив’язка груп до спеціальностей</h3>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    Нова прив’язка
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Група
                    </label>

                    <select class="form-select"
                            @bind="selectedGroupId">
                        <option value="0">
                            -- Оберіть групу --
                        </option>

                        @if (groups != null)
                        {
                            @foreach (var group in groups)
                            {
                                <option value="@group.Id">
                                    @group.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Спеціальність
                    </label>

                    <select class="form-select"
                            @bind="selectedSpecialtyId">
                        <option value="0">
                            -- Оберіть спеціальність --
                        </option>

                        @if (specialties != null)
                        {
                            @foreach (var specialty in specialties)
                            {
                                <option value="@specialty.Id">
                                    @specialty.Code — @specialty.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <button class="btn btn-primary w-100"
                        disabled="@isSaving"
                        @onclick="CreateGroupSpecialty">
                    Додати прив’язку
                </button>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Наявні прив’язки
                </h5>

                <span class="badge bg-primary">
                    Усього: @(groupSpecialties?.Count ?? 0)
                </span>
            </div>

            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Фільтр за групою
                        </label>

                        <select class="form-select"
                                @bind="filterGroupId">
                            <option value="0">
                                Усі групи
                            </option>

                            @if (groups != null)
                            {
                                @foreach (var group in groups)
                                {
                                    <option value="@group.Id">
                                        @group.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Фільтр за спеціальністю
                        </label>

                        <select class="form-select"
                                @bind="filterSpecialtyId">
                            <option value="0">
                                Усі спеціальності
                            </option>

                            @if (specialties != null)
                            {
                                @foreach (var specialty in specialties)
                                {
                                    <option value="@specialty.Id">
                                        @specialty.Code — @specialty.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-body p-0 border-top">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження прив’язок...
                    </div>
                }
                else if (!FilteredItems.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Прив’язок за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 10%">
                                        ID
                                    </th>

                                    <th style="width: 30%">
                                        Група
                                    </th>

                                    <th>
                                        Спеціальність
                                    </th>

                                    <th style="width: 18%"
                                        class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredItems)
                                {
                                    <tr>
                                        <td>
                                            @item.Id
                                        </td>

                                        <td class="fw-bold">
                                            @(item.Group?.Name
                                                ?? $"ID {item.GroupId}")
                                        </td>

                                        <td>
                                            @if (item.Specialty != null)
                                            {
                                                <span class="badge bg-primary me-2">
                                                    @item.Specialty.Code
                                                </span>

                                                <span>
                                                    @item.Specialty.Name
                                                </span>
                                            }
                                            else
                                            {
                                                <span>
                                                    ID @item.SpecialtyId
                                                </span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@(deletingId == item.Id)"
                                                    @onclick="() => DeleteGroupSpecialty(item.Id)">
                                                Видалити
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Group>? groups;
    private List<Specialty>? specialties;
    private List<GroupSpecialty>? groupSpecialties;

    private int selectedGroupId;
    private int selectedSpecialtyId;

    private int filterGroupId;
    private int filterSpecialtyId;

    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<GroupSpecialty> FilteredItems
    {
        get
        {
            IEnumerable<GroupSpecialty> result =
                groupSpecialties ?? [];

            if (filterGroupId > 0)
            {
                result = result.Where(
                    x => x.GroupId == filterGroupId);
            }

            if (filterSpecialtyId > 0)
            {
                result = result.Where(
                    x => x.SpecialtyId == filterSpecialtyId);
            }

            return result
                .OrderBy(x => x.Group?.Name)
                .ThenBy(x => x.Specialty?.Code)
                .ThenBy(x => x.Specialty?.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var groupsTask =
                Http.GetFromJsonAsync<List<Group>>(
                    "api/groups");

            var specialtiesTask =
                Http.GetFromJsonAsync<List<Specialty>>(
                    "api/specialties");

            var linksTask =
                Http.GetFromJsonAsync<List<GroupSpecialty>>(
                    "api/groupspecialties");

            await Task.WhenAll(
                groupsTask,
                specialtiesTask,
                linksTask);

            groups =
                groupsTask.Result
                ?? [];

            specialties =
                specialtiesTask.Result
                ?? [];

            groupSpecialties =
                linksTask.Result
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateGroupSpecialty()
    {
        if (selectedGroupId <= 0)
        {
            ShowError(
                "Потрібно обрати групу.");

            return;
        }

        if (selectedSpecialtyId <= 0)
        {
            ShowError(
                "Потрібно обрати спеціальність.");

            return;
        }

        isSaving = true;

        try
        {
            var item = new GroupSpecialty
            {
                GroupId = selectedGroupId,
                SpecialtyId = selectedSpecialtyId
            };

            var response =
                await Http.PostAsJsonAsync(
                    "api/groupspecialties",
                    item);

            if (response.IsSuccessStatusCode)
            {
                selectedGroupId = 0;
                selectedSpecialtyId = 0;

                await LoadGroupSpecialties();

                ShowSuccess(
                    "Групу прив’язано до спеціальності.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося створити прив’язку."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteGroupSpecialty(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/groupspecialties/{id}");

            if (response.IsSuccessStatusCode)
            {
                await LoadGroupSpecialties();

                ShowSuccess(
                    "Прив’язку видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити прив’язку."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadGroupSpecialties()
    {
        groupSpecialties =
            await Http.GetFromJsonAsync<List<GroupSpecialty>>(
                "api/groupspecialties")
            ?? [];
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Така прив’язка вже існує.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність вибраних даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
