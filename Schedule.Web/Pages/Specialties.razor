@page "/specialties"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-4">🎓 Довідник спеціальностей</h3>

<div class="row g-4">
    <div class="crud-form-column">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування спеціальності"
                        : "Нова спеціальність")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Код спеціальності
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="Наприклад: F7"
                           maxlength="20"
                           @bind="form.Code" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Назва спеціальності
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="Наприклад: Комп'ютерні науки"
                           maxlength="200"
                           @bind="form.Name" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveSpecialty">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати спеціальність")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="crud-data-column">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Список спеціальностей
                </h5>

                <span class="badge bg-primary">
                    Усього: @(specialties?.Count ?? 0)
                </span>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження спеціальностей...
                    </div>
                }
                else if (specialties == null ||
                         specialties.Count == 0)
                {
                    <div class="p-4 text-center text-muted">
                        Спеціальностей поки немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 10%">
                                        ID
                                    </th>

                                    <th style="width: 20%">
                                        Код
                                    </th>

                                    <th>
                                        Назва
                                    </th>

                                    <th style="width: 28%"
                                        class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var specialty in specialties)
                                {
                                    <tr>
                                        <td>
                                            @specialty.Id
                                        </td>

                                        <td>
                                            <span class="badge bg-primary">
                                                @specialty.Code
                                            </span>
                                        </td>

                                        <td class="fw-bold">
                                            @specialty.Name
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(specialty)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == specialty.Id)"
                                                        @onclick="() => DeleteSpecialty(specialty.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Specialty>? specialties;

    private Specialty form = CreateEmptyForm();

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadSpecialties();
    }

    private async Task LoadSpecialties()
    {
        isLoading = true;

        try
        {
            specialties =
                await Http.GetFromJsonAsync<List<Specialty>>(
                    "api/specialties")
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSpecialty()
    {
        if (string.IsNullOrWhiteSpace(form.Code))
        {
            ShowError(
                "Код спеціальності не може бути порожнім.");

            return;
        }

        if (string.IsNullOrWhiteSpace(form.Name))
        {
            ShowError(
                "Назва спеціальності не може бути порожньою.");

            return;
        }

        isSaving = true;

        try
        {
            form.Code = form.Code.Trim();
            form.Name = form.Name.Trim();

            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/specialties/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/specialties",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing = editingId.HasValue;

                ResetForm();

                await LoadSpecialties();

                ShowSuccess(
                    wasEditing
                        ? "Спеціальність оновлено."
                        : "Спеціальність додано.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти спеціальність."));
        }
        catch (Exception ex)
        {
            ShowError($"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(Specialty specialty)
    {
        editingId = specialty.Id;

        form = new Specialty
        {
            Id = specialty.Id,
            Code = specialty.Code,
            Name = specialty.Name
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteSpecialty(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/specialties/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadSpecialties();

                ShowSuccess(
                    "Спеціальність видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити спеціальність."));
        }
        catch (Exception ex)
        {
            ShowError($"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static Specialty CreateEmptyForm()
    {
        return new Specialty
        {
            Code = "",
            Name = ""
        };
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Операцію неможливо виконати через пов'язані дані.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність введених даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
