@page "/teachers"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">👨‍🏫 Довідник викладачів</h3>

<p class="text-muted mb-4">
    Тут зберігаються основні дані викладачів.
    Навантаження на семестр задається окремо.
</p>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування викладача"
                        : "Новий викладач")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        ПІБ викладача
                    </label>

                    <input type="text"
                           class="form-control"
                           maxlength="100"
                           placeholder="Наприклад: Іваненко Іван Іванович"
                           @bind="form.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Посада або науковий ступінь
                    </label>

                    <input type="text"
                           class="form-control"
                           maxlength="100"
                           placeholder="Наприклад: Доцент, к.т.н."
                           @bind="form.Position" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveTeacher">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати викладача")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Список викладачів
                </h5>

                <span class="badge bg-primary">
                    Усього: @(teachers?.Count ?? 0)
                </span>
            </div>

            <div class="card-body border-bottom">
                <label class="form-label small fw-bold">
                    Пошук
                </label>

                <input type="text"
                       class="form-control"
                       placeholder="ПІБ або посада"
                       @bind="searchText"
                       @bind:event="oninput" />
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження викладачів...
                    </div>
                }
                else if (!FilteredTeachers.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Викладачів за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 10%">
                                        ID
                                    </th>

                                    <th>
                                        ПІБ
                                    </th>

                                    <th style="width: 30%">
                                        Посада
                                    </th>

                                    <th style="width: 25%"
                                        class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var teacher in FilteredTeachers)
                                {
                                    <tr>
                                        <td>
                                            @teacher.Id
                                        </td>

                                        <td class="fw-bold">
                                            @teacher.Name
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(
                                                teacher.Position)
                                                ? "—"
                                                : teacher.Position)
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(teacher)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == teacher.Id)"
                                                        @onclick="() => DeleteTeacher(teacher.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Teacher>? teachers;

    private Teacher form = CreateEmptyForm();

    private string searchText = "";

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<Teacher> FilteredTeachers
    {
        get
        {
            IEnumerable<Teacher> result =
                teachers ?? [];

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                string value =
                    searchText.Trim();

                result = result.Where(
                    x =>
                        x.Name.Contains(
                            value,
                            StringComparison.OrdinalIgnoreCase)
                        ||
                        (
                            x.Position != null
                            &&
                            x.Position.Contains(
                                value,
                                StringComparison.OrdinalIgnoreCase)
                        ));
            }

            return result.OrderBy(x => x.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTeachers();
    }

    private async Task LoadTeachers()
    {
        isLoading = true;

        try
        {
            teachers =
                await Http.GetFromJsonAsync<List<Teacher>>(
                    "api/teachers")
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveTeacher()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            ShowError(
                "ПІБ викладача не може бути порожнім.");

            return;
        }

        isSaving = true;

        try
        {
            form.Name = form.Name.Trim();

            form.Position =
                string.IsNullOrWhiteSpace(form.Position)
                    ? null
                    : form.Position.Trim();

            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/teachers/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/teachers",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadTeachers();

                ShowSuccess(
                    wasEditing
                        ? "Дані викладача оновлено."
                        : "Викладача додано.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти викладача."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(Teacher teacher)
    {
        editingId = teacher.Id;

        form = new Teacher
        {
            Id = teacher.Id,
            Name = teacher.Name,
            Position = teacher.Position
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteTeacher(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/teachers/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadTeachers();

                ShowSuccess(
                    "Викладача видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити викладача."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static Teacher CreateEmptyForm()
    {
        return new Teacher
        {
            Name = "",
            Position = null
        };
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Викладач із таким ПІБ уже існує " +
                "або використовується в інших даних.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність введених даних.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}