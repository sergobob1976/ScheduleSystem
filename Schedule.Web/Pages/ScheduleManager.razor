@page "/schedule"
@using Schedule.Core.DTOs
@using Schedule.Core.Enums
@using Schedule.Core.Models
@using Schedule.Core.Services
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

<h1 class="h3 mb-3">Реальний розклад</h1>
<p class="text-muted">Перенесення базового шаблону календарними тижнями та керування фактичними заняттями.</p>

<div class="card shadow-sm mb-4"><div class="card-body"><div class="row g-3 align-items-end">
    <div class="col-md-3"><label class="form-label fw-bold">Семестр</label><select class="form-select" @bind="semesterId" @bind:after="ChangeSemester">
        <option value="0">Оберіть семестр</option>@foreach (var item in semesters) { <option value="@item.Id">@item.Name</option> }
    </select></div>
    <div class="col-md-4"><label class="form-label fw-bold">Календарний тиждень</label><select class="form-select" @bind="weekStart" @bind:after="LoadSchedule">
        <option value="">Оберіть тиждень</option>@foreach (var item in weeks) { <option value="@item.WeekStartDate.ToString("yyyy-MM-dd")">@item.ActiveStartDate.ToString("dd.MM")–@item.ActiveEndDate.ToString("dd.MM.yyyy") · @item.RecommendedWeekPropertyName @(item.IsTransferred ? $"· перенесено: {item.TransferredLessonCount} занять" : "")</option> }
    </select></div>
    <div class="col-md-3"><label class="form-label fw-bold">Фільтр групи</label><select class="form-select" @bind="scheduleGroupId" @bind:after="LoadSchedule"><option value="0">Усі групи</option>@foreach(var group in AvailableGroups){<option value="@group.Id">@group.Name</option>}</select></div>
    <div class="col-md-2"><button class="btn btn-primary w-100" disabled="@(SelectedWeek is null || SelectedWeek.IsTransferred || isTransferring || isLoadingSchedule)" @onclick="TransferWeek">@(isTransferring ? "Перенесення…" : "Перенести")</button></div>
</div></div></div>

@if (!string.IsNullOrWhiteSpace(errorMessage)) { <div class="alert alert-danger">@errorMessage</div> }
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success d-flex justify-content-between align-items-center gap-3">
        <span>@successMessage</span>
        <button type="button" class="btn btn-sm btn-success" @onclick="DismissSuccessMessage">ОК</button>
    </div>
}

@if (SelectedWeek is not null)
{
    <div class="card shadow-sm mb-4"><div class="card-body d-flex flex-wrap gap-4 align-items-center">
        <div><div class="small text-muted">Рекомендований тип</div><strong>@SelectedWeek.RecommendedWeekPropertyName</strong></div>
        <div><div class="small text-muted">Фактично перенесено</div><strong>@(SelectedWeek.TransferredWeekPropertyName ?? "Ще не перенесено")</strong></div>
        <div><div class="small text-muted">Створено занять</div><strong>@(SelectedWeek.IsTransferred ? SelectedWeek.TransferredLessonCount.ToString() : "—")</strong></div>
        <div><label class="form-label small fw-bold mb-1">Тип для перенесення</label><select class="form-select form-select-sm" disabled="@(SelectedWeek.IsTransferred || isTransferring)" @bind="transferProperty"><option value="@WeekProperty.Numerator">Чисельник</option><option value="@WeekProperty.Denominator">Знаменник</option></select></div>
        <div class="ms-auto"><button class="btn btn-outline-primary" disabled="@(!SelectedWeek.IsTransferred || isLoadingSchedule || isSavingLesson)" @onclick="OpenNewLesson">Додати заняття</button></div>
        @if (!SelectedWeek.IsTransferred && transferProperty != SelectedWeek.RecommendedWeekProperty)
        {
            <div class="alert alert-warning py-2 px-3 mb-0">Обрано тип тижня, відмінний від рекомендованого. Перенесення буде виконано за вибором диспетчера.</div>
        }
    </div></div>
}

@if (editingLesson is not null)
{
    <div class="card border-primary shadow-sm mb-4"><div class="card-header bg-primary text-white">@(isCreatingLesson ? "Нове реальне заняття" : "Редагування реального заняття")</div><div class="card-body"><div class="row g-3 align-items-end">
        <div class="col-md-3"><label class="form-label fw-bold">Дата</label><input type="date" class="form-control" min="@EditorMinDate" max="@EditorMaxDate" @bind="editingLesson.LessonDate" @bind:format="yyyy-MM-dd" /></div>
        <div class="col-md-2"><label class="form-label fw-bold">Пара</label><select class="form-select" @bind="editingLesson.LessonPosition">@for (var i=1;i<=8;i++){<option value="@i">@i</option>}</select></div>
        <div class="col-md-4"><label class="form-label fw-bold">Призначення</label><select class="form-select" @bind="editingLesson.TeachingAssignmentId"><option value="">Оберіть призначення</option>@foreach(var item in AvailableAssignments){<option value="@item.Id">@GetAssignmentGroupName(item) · @GetAssignmentDisciplineName(item) · @item.Teacher?.Name · @GetLessonTypeName(item.LessonType)</option>}</select></div>
        <div class="col-md-3"><label class="form-label fw-bold">Аудиторія</label><select class="form-select" @bind="editingLesson.ClassRoomId"><option value="">Без аудиторії</option>@foreach(var room in classRooms){<option value="@room.Id">@room.Name</option>}</select></div>
        <div class="col-md-6"><label class="form-label fw-bold">Посилання на конференцію</label><input class="form-control" type="url" placeholder="https://..." @bind="editingLesson.ConferenceLink" /></div>
        <div class="col-md-6"><label class="form-label fw-bold">Посилання на матеріали</label><input class="form-control" type="url" placeholder="https://..." @bind="editingLesson.ResourceLink" /></div>
        <div class="col-12 d-flex gap-2"><button class="btn btn-primary" disabled="@isSavingLesson" @onclick="SaveLesson">@(isSavingLesson ? "Збереження…" : isCreatingLesson ? "Створити заняття" : "Зберегти")</button><button class="btn btn-outline-secondary" disabled="@isSavingLesson" @onclick="CloseLessonEditor">Скасувати</button></div>
    </div></div></div>
}

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
        <strong>Заняття вибраного тижня</strong>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary">Усього: @lessons.Count</span>
            <span class="badge bg-secondary">Заплановано: @PlannedLessonCount</span>
            <span class="badge bg-success">Проведено: @CompletedLessonCount</span>
            <span class="badge bg-danger">Скасовано: @CancelledLessonCount</span>
        </div>
    </div>
    @if (isLoadingSchedule)
    {
        <div class="text-center text-muted py-4">Завантаження…</div>
    }
    else if (SelectedWeek is null)
    {
        <div class="text-center text-muted py-4">Оберіть календарний тиждень.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0 schedule-grid real-schedule-grid">
                <thead>
                    <tr>
                        <th class="real-schedule-position-header text-center">Пара</th>
                        @foreach (var date in DisplayedWeekDates)
                        {
                            <th class="real-schedule-day-header text-center">
                                <div>@GetDayName(ConvertToWeekDay(date))</div>
                                <div class="small fw-normal">@date.ToString("dd.MM.yyyy")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (var position = 1; position <= 8; position++)
                    {
                        var currentPosition = position;
                        <tr>
                            <th class="real-schedule-position text-center">@currentPosition</th>
                            @foreach (var date in DisplayedWeekDates)
                            {
                                var cellLessons = GetLessons(date, currentPosition).ToList();
                                <td class="schedule-cell real-schedule-cell">
                                    @if (cellLessons.Count == 0)
                                    {
                                        <span class="real-schedule-empty">—</span>
                                    }
                                    else
                                    {
                                        @foreach (var item in cellLessons)
                                        {
                                            <article class="real-lesson-card @GetGroupCardClass(item.GroupId)">
                                                <div class="real-lesson-group">@(item.Group?.Name ?? "Групу не вказано")</div>
                                                <div class="fw-semibold">@(item.Discipline?.Name ?? "Дисципліну не вказано")</div>
                                                <div class="small">@item.Teacher?.Name</div>
                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                    <span class="badge bg-secondary">@GetLessonTypeName(item.LessonType)</span>
                                                    <span class="badge bg-light text-dark border">@(item.ClassRoom?.Name ?? "Без аудиторії")</span>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(item.ResourceLink) || !string.IsNullOrWhiteSpace(item.ConferenceLink))
                                                {
                                                    <div class="d-flex flex-wrap gap-2 mt-1 small">
                                                        @if (!string.IsNullOrWhiteSpace(item.ResourceLink))
                                                        {
                                                            <a href="@item.ResourceLink" target="_blank" rel="noopener noreferrer">Матеріали</a>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(item.ConferenceLink))
                                                        {
                                                            <a href="@item.ConferenceLink" target="_blank" rel="noopener noreferrer">Конференція</a>
                                                        }
                                                    </div>
                                                }
                                                <select class="form-select form-select-sm status-select w-100 mt-2 @GetStatusClass(item.Status)"
                                                        aria-label="Стан заняття групи @(item.Group?.Name)"
                                                        disabled="@isChangingStatus"
                                                        value="@((int)item.Status)"
                                                        @onchange="args => ChangeStatus(item, args)">
                                                    <option value="0">Заплановано</option>
                                                    <option value="1">Проведено</option>
                                                    <option value="2">Скасовано</option>
                                                </select>
                                                <div class="d-flex flex-wrap gap-1 mt-2">
                                                    <button class="btn btn-sm btn-outline-primary" disabled="@(deletingLessonId > 0)" @onclick="() => EditLesson(item)">Редагувати</button>
                                                    <button class="btn btn-sm btn-outline-danger" disabled="@(deletingLessonId > 0)" @onclick="() => DeleteLesson(item.Id)">@(deletingLessonId == item.Id ? "Видалення…" : "Видалити")</button>
                                                </div>
                                            </article>
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="card shadow-sm mt-4"><div class="card-header bg-white"><strong>Фактична вичитка годин</strong></div><div class="card-body"><div class="row g-3 align-items-end">
    <div class="col-md-5"><label class="form-label fw-bold">Група</label><select class="form-select" @bind="reportGroupId" @bind:after="ClearGroupReport"><option value="0">Оберіть групу</option>@foreach(var group in AvailableGroups){<option value="@group.Id">@group.Name</option>}</select></div>
    <div class="col-md-4"><label class="form-label fw-bold">Станом на дату</label><input type="date" class="form-control" @bind="reportDate" @bind:format="yyyy-MM-dd" @bind:after="ClearGroupReport" /></div>
    <div class="col-md-3"><button class="btn btn-outline-primary w-100" disabled="@isLoadingGroupReport" @onclick="LoadHoursReport">@(isLoadingGroupReport ? "Завантаження…" : "Показати звіт")</button></div>
</div></div>
@if (hoursReport is not null) { <div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead class="table-light"><tr><th>Дисципліна</th><th>План</th><th>Проведено</th><th>Майбутні</th><th>Не підтверджено</th><th>Скасовано</th><th>Залишок</th></tr></thead><tbody>
@foreach(var item in hoursReport.Disciplines){<tr><td class="fw-semibold">@item.DisciplineName</td><td>@item.PlannedHours</td><td class="text-success">@item.CompletedHours</td><td>@item.PlannedFutureHours</td><td class="text-warning">@item.UnconfirmedPastHours</td><td class="text-danger">@item.CancelledHours</td><td class="fw-bold">@item.RemainingHours</td></tr>}
</tbody><tfoot class="table-light fw-bold"><tr><td>Усього</td><td>@hoursReport.Disciplines.Sum(x => x.PlannedHours)</td><td class="text-success">@hoursReport.Disciplines.Sum(x => x.CompletedHours)</td><td>@hoursReport.Disciplines.Sum(x => x.PlannedFutureHours)</td><td class="text-warning">@hoursReport.Disciplines.Sum(x => x.UnconfirmedPastHours)</td><td class="text-danger">@hoursReport.Disciplines.Sum(x => x.CancelledHours)</td><td>@hoursReport.Disciplines.Sum(x => x.RemainingHours)</td></tr></tfoot></table></div> }</div>

<div class="card shadow-sm mt-4"><div class="card-header bg-white"><strong>Вичитка годин викладача</strong></div><div class="card-body"><div class="row g-3 align-items-end">
    <div class="col-md-5"><label class="form-label fw-bold">Викладач</label><select class="form-select" @bind="reportTeacherId" @bind:after="ClearTeacherReport"><option value="0">Оберіть викладача</option>@foreach(var teacher in AvailableTeachers){<option value="@teacher.Id">@TeacherNameFormatter.ToNameSurname(teacher.Name)</option>}</select></div>
    <div class="col-md-4"><label class="form-label fw-bold">Станом на дату</label><input type="date" class="form-control" @bind="teacherReportDate" @bind:format="yyyy-MM-dd" @bind:after="ClearTeacherReport" /></div>
    <div class="col-md-3"><button class="btn btn-outline-primary w-100" disabled="@isLoadingTeacherReport" @onclick="LoadTeacherHoursReport">@(isLoadingTeacherReport ? "Завантаження…" : "Показати звіт")</button></div>
</div></div>
@if (teacherHoursReport is not null) { <div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead class="table-light"><tr><th>Дисципліна</th><th>План</th><th>Проведено</th><th>Майбутні</th><th>Не підтверджено</th><th>Скасовано</th><th>Залишок</th></tr></thead><tbody>
@foreach(var item in teacherHoursReport.Disciplines){<tr><td class="fw-semibold">@item.DisciplineName</td><td>@item.PlannedHours</td><td class="text-success">@item.CompletedHours</td><td>@item.PlannedFutureHours</td><td class="text-warning">@item.UnconfirmedPastHours</td><td class="text-danger">@item.CancelledHours</td><td class="fw-bold">@item.RemainingHours</td></tr>}
</tbody><tfoot class="table-light fw-bold"><tr><td>Усього</td><td>@teacherHoursReport.Disciplines.Sum(x => x.PlannedHours)</td><td class="text-success">@teacherHoursReport.Disciplines.Sum(x => x.CompletedHours)</td><td>@teacherHoursReport.Disciplines.Sum(x => x.PlannedFutureHours)</td><td class="text-warning">@teacherHoursReport.Disciplines.Sum(x => x.UnconfirmedPastHours)</td><td class="text-danger">@teacherHoursReport.Disciplines.Sum(x => x.CancelledHours)</td><td>@teacherHoursReport.Disciplines.Sum(x => x.RemainingHours)</td></tr></tfoot></table></div> }</div>

@code {
    private List<Semester> semesters = [];
    private List<RealLessonTransferWeekOption> weeks = [];
    private List<RealLesson> lessons = [];
    private List<TeachingAssignment> assignments = [];
    private List<ClassRoom> classRooms = [];
    private List<Group> groups = [];
    private List<GroupDiscipline> groupDisciplines = [];
    private List<Discipline> disciplines = [];
    private List<Teacher> teachers = [];
    private List<TeacherSemesterLoad> teacherSemesterLoads = [];
    private RealLessonHoursReportResponse? hoursReport;
    private int reportGroupId;
    private DateTime reportDate = DateTime.Today;
    private TeacherLessonHoursReportResponse? teacherHoursReport;
    private int reportTeacherId;
    private DateTime teacherReportDate = DateTime.Today;
    private RealLesson? editingLesson;
    private int semesterId;
    private int scheduleGroupId;
    private bool isTransferring;
    private bool isSavingLesson;
    private bool isChangingStatus;
    private int deletingLessonId;
    private bool isLoadingSchedule;
    private bool isLoadingGroupReport;
    private bool isLoadingTeacherReport;
    private bool isCreatingLesson;
    private string weekStart = "";
    private WeekProperty transferProperty = WeekProperty.Numerator;
    private string errorMessage = "";
    private string successMessage = "";
    private RealLessonTransferWeekOption? SelectedWeek => weeks.FirstOrDefault(x => x.WeekStartDate.ToString("yyyy-MM-dd") == weekStart);
    private Semester? SelectedSemester => semesters.FirstOrDefault(x => x.Id == semesterId);
    private IEnumerable<TeachingAssignment> AvailableAssignments => assignments.Where(x =>
        x.GroupDiscipline?.SemesterId == semesterId &&
        (scheduleGroupId <= 0 || x.GroupDiscipline.GroupId == scheduleGroupId));
    private IEnumerable<Group> AvailableGroups => semesterId <= 0
        ? []
        : groups.Where(group => groupDisciplines.Any(item =>
            item.SemesterId == semesterId && item.GroupId == group.Id));
    private IEnumerable<Teacher> AvailableTeachers => semesterId <= 0
        ? []
        : teachers.Where(teacher => teacherSemesterLoads.Any(item =>
            item.SemesterId == semesterId && item.TeacherId == teacher.Id));
    private string EditorMinDate => (isCreatingLesson ? SelectedWeek?.ActiveStartDate : SelectedSemester?.StartDate)?.ToString("yyyy-MM-dd") ?? "";
    private string EditorMaxDate => (isCreatingLesson ? SelectedWeek?.ActiveEndDate : SelectedSemester?.EndDate)?.ToString("yyyy-MM-dd") ?? "";
    private int PlannedLessonCount => lessons.Count(x => x.Status == RealLessonStatus.Planned);
    private int CompletedLessonCount => lessons.Count(x => x.Status == RealLessonStatus.Completed);
    private int CancelledLessonCount => lessons.Count(x => x.Status == RealLessonStatus.Cancelled);
    private IEnumerable<DateTime> DisplayedWeekDates
    {
        get
        {
            var week = SelectedWeek;
            if (week is null) return [];

            var dayCount = (week.ActiveEndDate.Date - week.ActiveStartDate.Date).Days + 1;
            return Enumerable.Range(0, Math.Max(0, dayCount))
                .Select(offset => week.ActiveStartDate.Date.AddDays(offset));
        }
    }

    private IEnumerable<RealLesson> GetLessons(DateTime date, int lessonPosition) =>
        lessons
            .Where(item => item.LessonDate.Date == date.Date && item.LessonPosition == lessonPosition)
            .OrderBy(item => item.Group?.Name)
            .ThenBy(item => item.Discipline?.Name);

    private static string GetGroupCardClass(int groupId) => $"real-group-color-{(groupId & int.MaxValue) % 6}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            semesters = await Http.GetFromJsonAsync<List<Semester>>("api/semesters") ?? [];
            SelectDefaultSemester();
            assignments = await Http.GetFromJsonAsync<List<TeachingAssignment>>("api/teachingassignments") ?? [];
            classRooms = await Http.GetFromJsonAsync<List<ClassRoom>>("api/classrooms") ?? [];
            groups = await Http.GetFromJsonAsync<List<Group>>("api/groups") ?? [];
            groupDisciplines = await Http.GetFromJsonAsync<List<GroupDiscipline>>("api/groupdisciplines") ?? [];
            disciplines = await Http.GetFromJsonAsync<List<Discipline>>("api/disciplines") ?? [];
            teachers = await Http.GetFromJsonAsync<List<Teacher>>("api/teachers") ?? [];
            teacherSemesterLoads = await Http.GetFromJsonAsync<List<TeacherSemesterLoad>>("api/teachersemesterloads") ?? [];
            await LoadWeeks();
            if (!string.IsNullOrWhiteSpace(weekStart)) await LoadSchedule();
        }
        catch (Exception)
        {
            errorMessage = "Не вдалося завантажити довідкові дані для реального розкладу. Перевірте з’єднання із сервером і оновіть сторінку.";
        }
    }

    private void SelectDefaultSemester()
    {
        var today = DateTime.Today;
        var semester = semesters
            .Where(item => item.StartDate.Date <= today && item.EndDate.Date >= today)
            .OrderBy(item => item.StartDate)
            .FirstOrDefault()
            ?? semesters.Where(item => item.StartDate.Date > today).OrderBy(item => item.StartDate).FirstOrDefault()
            ?? semesters.Where(item => item.EndDate.Date < today).OrderByDescending(item => item.EndDate).FirstOrDefault();
        semesterId = semester?.Id ?? 0;
    }

    private void DismissSuccessMessage() => successMessage = "";
    private async Task ChangeSemester()
    {
        scheduleGroupId = 0;
        reportGroupId = 0;
        reportTeacherId = 0;
        hoursReport = null;
        teacherHoursReport = null;
        editingLesson = null;
        isCreatingLesson = false;
        errorMessage = "";
        successMessage = "";
        await LoadWeeks();
        if (!string.IsNullOrWhiteSpace(weekStart)) await LoadSchedule();
    }
    private async Task LoadWeeks()
    {
        weeks = semesterId > 0
            ? await Http.GetFromJsonAsync<List<RealLessonTransferWeekOption>>($"api/RealLessons/transfer-week-options/semester/{semesterId}") ?? []
            : [];
        weekStart = "";
        lessons = [];

        var today = DateTime.Today;
        var currentWeek = weeks.FirstOrDefault(item =>
            item.ActiveStartDate.Date <= today && item.ActiveEndDate.Date >= today);
        if (currentWeek is not null)
        {
            weekStart = currentWeek.WeekStartDate.ToString("yyyy-MM-dd");
        }
    }
    private async Task LoadSchedule()
    {
        errorMessage = "";
        successMessage = "";
        lessons = [];
        CloseLessonEditor();
        var week = SelectedWeek;
        if (week is null) return;
        transferProperty = week.RecommendedWeekProperty;
        var groupQuery = scheduleGroupId > 0 ? $"?groupId={scheduleGroupId}" : "";
        isLoadingSchedule = true;
        try
        {
            lessons = await Http.GetFromJsonAsync<List<RealLesson>>($"api/RealLessons/semester/{semesterId}/week/{week.WeekStartDate:yyyy-MM-dd}{groupQuery}") ?? [];
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося завантажити реальний розклад. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isLoadingSchedule = false;
        }
    }
    private async Task TransferWeek()
    {
        var week = SelectedWeek; if (week is null) return;
        var weekPropertyName = transferProperty == WeekProperty.Numerator
            ? "Чисельник"
            : "Знаменник";
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Перенести весь тиждень {week.ActiveStartDate:dd.MM.yyyy}–{week.ActiveEndDate:dd.MM.yyyy} ({weekPropertyName}) до реального розкладу?");
        if (!confirmed) return;

        errorMessage = "";
        successMessage = "";
        isTransferring = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/RealLessons/transfer-week", new TransferRealLessonWeekRequest { SemesterId = semesterId, WeekStartDate = week.WeekStartDate, WeekProperty = transferProperty });
            if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); return; }
            var result = await response.Content.ReadFromJsonAsync<TransferRealLessonWeekResponse>();
            weekStart = week.WeekStartDate.ToString("yyyy-MM-dd");
            await ReloadWeekOptionsAndSchedule();
            await RefreshLoadedReports();
            successMessage = result is null
                ? "Тиждень успішно перенесено до реального розкладу."
                : $"Тиждень успішно перенесено. Створено занять: {result.CreatedLessonCount}.";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося перенести тиждень. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isTransferring = false;
        }
    }
    private async Task ChangeStatus(RealLesson lesson, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var value) || !Enum.IsDefined(typeof(RealLessonStatus), value)) return;
        var status = (RealLessonStatus)value;
        isChangingStatus = true;
        errorMessage = "";
        successMessage = "";
        try
        {
            var response = await Http.PatchAsJsonAsync($"api/RealLessons/{lesson.Id}/status", new UpdateRealLessonStatusRequest { Status = status });
            if (!response.IsSuccessStatusCode)
            {
                var message = await ReadMessage(response);
                await LoadSchedule();
                errorMessage = message;
                return;
            }
            lesson.Status = status;
            await RefreshLoadedReports();
            successMessage = $"Стан заняття змінено на «{GetStatusName(status)}».";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося змінити стан заняття. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isChangingStatus = false;
        }
    }
    private void OpenNewLesson()
    {
        var week = SelectedWeek;
        if (week is null || !week.IsTransferred) return;
        isCreatingLesson = true;
        editingLesson = new RealLesson
        {
            LessonDate = week.ActiveStartDate,
            LessonPosition = 1,
            WeekDay = ConvertToWeekDay(week.ActiveStartDate),
            WeekProperty = week.TransferredWeekProperty ?? week.RecommendedWeekProperty,
            LessonType = LessonType.Lecture,
            Status = RealLessonStatus.Planned
        };
        errorMessage = "";
        successMessage = "";
    }

    private void EditLesson(RealLesson source)
    {
        isCreatingLesson = false;
        editingLesson = new RealLesson { Id=source.Id, TeachingAssignmentId=source.TeachingAssignmentId, GroupId=source.GroupId, TeacherId=source.TeacherId, DisciplineId=source.DisciplineId, ClassRoomId=source.ClassRoomId, SemesterId=source.SemesterId, LessonDate=source.LessonDate, LessonPosition=source.LessonPosition, WeekDay=source.WeekDay, WeekProperty=source.WeekProperty, LessonType=source.LessonType, Status=source.Status, ConferenceLink=source.ConferenceLink, ResourceLink=source.ResourceLink };
    }

    private void CloseLessonEditor()
    {
        editingLesson = null;
        isCreatingLesson = false;
    }
    private async Task SaveLesson()
    {
        if (editingLesson is null) return;
        if (!editingLesson.TeachingAssignmentId.HasValue || editingLesson.TeachingAssignmentId.Value <= 0)
        {
            errorMessage = "Оберіть призначення викладача.";
            return;
        }
        if (isCreatingLesson && SelectedWeek is { } week &&
            (editingLesson.LessonDate.Date < week.ActiveStartDate.Date ||
             editingLesson.LessonDate.Date > week.ActiveEndDate.Date))
        {
            errorMessage = $"Дата нового заняття повинна бути в межах вибраного тижня: {week.ActiveStartDate:dd.MM.yyyy}–{week.ActiveEndDate:dd.MM.yyyy}.";
            return;
        }
        isSavingLesson = true;
        errorMessage = "";
        successMessage = "";
        try
        {
            var response = isCreatingLesson
                ? await Http.PostAsJsonAsync("api/RealLessons", editingLesson)
                : await Http.PutAsJsonAsync($"api/RealLessons/{editingLesson.Id}", editingLesson);
            if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); return; }
            var created = isCreatingLesson;
            CloseLessonEditor();
            await ReloadWeekOptionsAndSchedule();
            await RefreshLoadedReports();
            successMessage = created ? "Реальне заняття успішно створено." : "Реальне заняття успішно оновлено.";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося зберегти заняття. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isSavingLesson = false;
        }
    }
    private async Task DeleteLesson(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Видалити це заняття з реального розкладу?")) return;
        deletingLessonId = id;
        errorMessage = "";
        successMessage = "";
        try
        {
            var response = await Http.DeleteAsync($"api/RealLessons/{id}");
            if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); return; }
            if (editingLesson?.Id == id) editingLesson = null;
            await ReloadWeekOptionsAndSchedule();
            await RefreshLoadedReports();
            successMessage = "Реальне заняття успішно видалено.";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося видалити заняття. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            deletingLessonId = 0;
        }
    }
    private async Task LoadHoursReport()
    {
        if (semesterId <= 0 || reportGroupId <= 0) { errorMessage = "Оберіть семестр і групу для звіту."; return; }
        errorMessage = "";
        isLoadingGroupReport = true;
        try
        {
            hoursReport = await Http.GetFromJsonAsync<RealLessonHoursReportResponse>($"api/RealLessonReports/semester/{semesterId}/group/{reportGroupId}/hours?reportDate={reportDate:yyyy-MM-dd}");
        }
        catch (Exception)
        {
            hoursReport = null;
            errorMessage = "Не вдалося завантажити звіт групи. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isLoadingGroupReport = false;
        }
    }

    private void ClearGroupReport()
    {
        hoursReport = null;
        errorMessage = "";
        successMessage = "";
    }

    private async Task LoadTeacherHoursReport()
    {
        if (semesterId <= 0 || reportTeacherId <= 0) { errorMessage = "Оберіть семестр і викладача для звіту."; return; }
        errorMessage = "";
        isLoadingTeacherReport = true;
        try
        {
            teacherHoursReport = await Http.GetFromJsonAsync<TeacherLessonHoursReportResponse>($"api/RealLessonReports/semester/{semesterId}/teacher/{reportTeacherId}/hours?reportDate={teacherReportDate:yyyy-MM-dd}");
        }
        catch (Exception)
        {
            teacherHoursReport = null;
            errorMessage = "Не вдалося завантажити звіт викладача. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isLoadingTeacherReport = false;
        }
    }

    private void ClearTeacherReport()
    {
        teacherHoursReport = null;
        errorMessage = "";
        successMessage = "";
    }
    private async Task RefreshLoadedReports()
    {
        if (hoursReport is not null) await LoadHoursReport();
        if (teacherHoursReport is not null) await LoadTeacherHoursReport();
    }

    private async Task ReloadWeekOptionsAndSchedule()
    {
        var selectedWeekStart = weekStart;
        await LoadWeeks();
        weekStart = selectedWeekStart;
        await LoadSchedule();
    }
    private static async Task<string> ReadMessage(HttpResponseMessage response) { var text = await response.Content.ReadAsStringAsync(); try { using var json = JsonDocument.Parse(text); if (json.RootElement.TryGetProperty("message", out var value)) return value.GetString() ?? "Операцію не виконано."; } catch (JsonException) { } return "Операцію не виконано. Перевірте з’єднання із сервером і повторіть спробу."; }
    private static string GetStatusName(RealLessonStatus status) => status switch { RealLessonStatus.Completed => "Проведено", RealLessonStatus.Cancelled => "Скасовано", _ => "Заплановано" };
    private static string GetStatusClass(RealLessonStatus status) => status switch { RealLessonStatus.Completed => "border-success text-success", RealLessonStatus.Cancelled => "border-danger text-danger", _ => "border-secondary" };
    private static string GetLessonTypeName(LessonType value) => value switch
    { LessonType.Lecture => "Лекція", LessonType.Practical => "Практичне", LessonType.Laboratory => "Лабораторне", LessonType.Seminar => "Семінар", _ => "Інше" };
    private GroupDiscipline? GetAssignmentGroupDiscipline(TeachingAssignment assignment) =>
        assignment.GroupDiscipline ?? groupDisciplines.FirstOrDefault(x => x.Id == assignment.GroupDisciplineId);
    private string GetAssignmentGroupName(TeachingAssignment assignment)
    {
        var groupDiscipline = GetAssignmentGroupDiscipline(assignment);
        return groupDiscipline?.Group?.Name ??
            groups.FirstOrDefault(x => x.Id == groupDiscipline?.GroupId)?.Name ??
            "Групу не знайдено";
    }
    private string GetAssignmentDisciplineName(TeachingAssignment assignment)
    {
        var groupDiscipline = GetAssignmentGroupDiscipline(assignment);
        return groupDiscipline?.Discipline?.Name ??
            disciplines.FirstOrDefault(x => x.Id == groupDiscipline?.DisciplineId)?.Name ??
            "Дисципліну не знайдено";
    }
    private static string GetDayName(WeekDay day) => day switch
    {
        WeekDay.Monday => "Понеділок", WeekDay.Tuesday => "Вівторок",
        WeekDay.Wednesday => "Середа", WeekDay.Thursday => "Четвер",
        WeekDay.Friday => "П’ятниця", WeekDay.Saturday => "Субота",
        WeekDay.Sunday => "Неділя", _ => "—"
    };
    private static WeekDay ConvertToWeekDay(DateTime date) => date.DayOfWeek switch
    {
        DayOfWeek.Monday => WeekDay.Monday,
        DayOfWeek.Tuesday => WeekDay.Tuesday,
        DayOfWeek.Wednesday => WeekDay.Wednesday,
        DayOfWeek.Thursday => WeekDay.Thursday,
        DayOfWeek.Friday => WeekDay.Friday,
        DayOfWeek.Saturday => WeekDay.Saturday,
        DayOfWeek.Sunday => WeekDay.Sunday,
        _ => WeekDay.Monday
    };
}
