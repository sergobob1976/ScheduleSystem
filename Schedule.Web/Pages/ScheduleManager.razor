@page "/schedule"
@using Schedule.Core.DTOs
@using Schedule.Core.Enums
@using Schedule.Core.Models
@using System.Text.Json
@inject HttpClient Http

<h1 class="h3 mb-3">Реальний розклад</h1>
<p class="text-muted">Перенесення базового шаблону календарними тижнями та керування фактичними заняттями.</p>

<div class="card shadow-sm mb-4"><div class="card-body"><div class="row g-3 align-items-end">
    <div class="col-md-4"><label class="form-label fw-bold">Семестр</label><select class="form-select" @bind="semesterId" @bind:after="LoadWeeks">
        <option value="0">Оберіть семестр</option>@foreach (var item in semesters) { <option value="@item.Id">@item.Name</option> }
    </select></div>
    <div class="col-md-5"><label class="form-label fw-bold">Календарний тиждень</label><select class="form-select" @bind="weekStart" @bind:after="LoadSchedule">
        <option value="">Оберіть тиждень</option>@foreach (var item in weeks) { <option value="@item.WeekStartDate.ToString("yyyy-MM-dd")">@item.ActiveStartDate.ToString("dd.MM")–@item.ActiveEndDate.ToString("dd.MM.yyyy") · @item.RecommendedWeekPropertyName @(item.IsTransferred ? "· перенесено" : "")</option> }
    </select></div>
    <div class="col-md-3"><button class="btn btn-primary w-100" disabled="@(SelectedWeek is null || SelectedWeek.IsTransferred)" @onclick="TransferWeek">Перенести тиждень</button></div>
</div></div></div>

@if (!string.IsNullOrWhiteSpace(errorMessage)) { <div class="alert alert-danger">@errorMessage</div> }
else if (!string.IsNullOrWhiteSpace(successMessage)) { <div class="alert alert-success">@successMessage</div> }

@if (SelectedWeek is not null)
{
    <div class="card shadow-sm mb-4"><div class="card-body d-flex flex-wrap gap-4 align-items-center">
        <div><div class="small text-muted">Рекомендований тип</div><strong>@SelectedWeek.RecommendedWeekPropertyName</strong></div>
        <div><div class="small text-muted">Фактично перенесено</div><strong>@(SelectedWeek.TransferredWeekPropertyName ?? "Ще не перенесено")</strong></div>
        <div><label class="form-label small fw-bold mb-1">Тип для перенесення</label><select class="form-select form-select-sm" @bind="transferProperty"><option value="@WeekProperty.Numerator">Чисельник</option><option value="@WeekProperty.Denominator">Знаменник</option></select></div>
    </div></div>
}

@if (editingLesson is not null)
{
    <div class="card border-primary shadow-sm mb-4"><div class="card-header bg-primary text-white">Редагування реального заняття</div><div class="card-body"><div class="row g-3 align-items-end">
        <div class="col-md-3"><label class="form-label fw-bold">Дата</label><input type="date" class="form-control" @bind="editingLesson.LessonDate" @bind:format="yyyy-MM-dd" /></div>
        <div class="col-md-2"><label class="form-label fw-bold">Пара</label><select class="form-select" @bind="editingLesson.LessonPosition">@for (var i=1;i<=8;i++){<option value="@i">@i</option>}</select></div>
        <div class="col-md-4"><label class="form-label fw-bold">Призначення</label><select class="form-select" @bind="editingLesson.TeachingAssignmentId">@foreach(var item in AvailableAssignments){<option value="@item.Id">@item.GroupDiscipline?.Group?.Name · @item.GroupDiscipline?.Discipline?.Name · @item.Teacher?.Name</option>}</select></div>
        <div class="col-md-3"><label class="form-label fw-bold">Аудиторія</label><select class="form-select" @bind="editingLesson.ClassRoomId"><option value="">Без аудиторії</option>@foreach(var room in classRooms){<option value="@room.Id">@room.Name</option>}</select></div>
        <div class="col-12 d-flex gap-2"><button class="btn btn-primary" @onclick="SaveLesson">Зберегти</button><button class="btn btn-outline-secondary" @onclick="() => editingLesson = null">Скасувати</button></div>
    </div></div></div>
}

<div class="card shadow-sm"><div class="card-header bg-white d-flex justify-content-between"><strong>Заняття вибраного тижня</strong><span class="badge bg-primary">@lessons.Count</span></div>
<div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Дата</th><th>Пара</th><th>Група</th><th>Дисципліна</th><th>Викладач</th><th>Аудиторія</th><th>Стан</th><th>Дії</th></tr></thead>
<tbody>@if (lessons.Count == 0) { <tr><td colspan="8" class="text-center text-muted py-4">Занять немає.</td></tr> }
else { @foreach (var item in lessons) { <tr><td>@item.LessonDate.ToString("dd.MM.yyyy")</td><td>@item.LessonPosition</td><td>@item.Group?.Name</td><td>@item.Discipline?.Name</td><td>@item.Teacher?.Name</td><td>@(item.ClassRoom?.Name ?? "—")</td><td>
    <select class="form-select form-select-sm status-select @GetStatusClass(item.Status)" value="@((int)item.Status)" @onchange="args => ChangeStatus(item, args)">
        <option value="0">Заплановано</option><option value="1">Проведено</option><option value="2">Скасовано</option>
    </select>
</td><td><button class="btn btn-sm btn-outline-primary" @onclick="() => EditLesson(item)">Редагувати</button></td></tr> } }</tbody></table></div></div>

<div class="card shadow-sm mt-4"><div class="card-header bg-white"><strong>Фактична вичитка годин</strong></div><div class="card-body"><div class="row g-3 align-items-end">
    <div class="col-md-5"><label class="form-label fw-bold">Група</label><select class="form-select" @bind="reportGroupId"><option value="0">Оберіть групу</option>@foreach(var group in groups){<option value="@group.Id">@group.Name</option>}</select></div>
    <div class="col-md-4"><label class="form-label fw-bold">Станом на дату</label><input type="date" class="form-control" @bind="reportDate" @bind:format="yyyy-MM-dd" /></div>
    <div class="col-md-3"><button class="btn btn-outline-primary w-100" @onclick="LoadHoursReport">Показати звіт</button></div>
</div></div>
@if (hoursReport is not null) { <div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead class="table-light"><tr><th>Дисципліна</th><th>План</th><th>Проведено</th><th>Майбутні</th><th>Не підтверджено</th><th>Скасовано</th><th>Залишок</th></tr></thead><tbody>
@foreach(var item in hoursReport.Disciplines){<tr><td class="fw-semibold">@item.DisciplineName</td><td>@item.PlannedHours</td><td class="text-success">@item.CompletedHours</td><td>@item.PlannedFutureHours</td><td class="text-warning">@item.UnconfirmedPastHours</td><td class="text-danger">@item.CancelledHours</td><td class="fw-bold">@item.RemainingHours</td></tr>}
</tbody></table></div> }</div>

@code {
    private List<Semester> semesters = [];
    private List<RealLessonTransferWeekOption> weeks = [];
    private List<RealLesson> lessons = [];
    private List<TeachingAssignment> assignments = [];
    private List<ClassRoom> classRooms = [];
    private List<Group> groups = [];
    private RealLessonHoursReportResponse? hoursReport;
    private int reportGroupId;
    private DateTime reportDate = DateTime.Today;
    private RealLesson? editingLesson;
    private int semesterId;
    private string weekStart = "";
    private WeekProperty transferProperty = WeekProperty.Numerator;
    private string errorMessage = "";
    private string successMessage = "";
    private RealLessonTransferWeekOption? SelectedWeek => weeks.FirstOrDefault(x => x.WeekStartDate.ToString("yyyy-MM-dd") == weekStart);
    private IEnumerable<TeachingAssignment> AvailableAssignments => assignments.Where(x => x.GroupDiscipline?.SemesterId == semesterId);

    protected override async Task OnInitializedAsync() { semesters = await Http.GetFromJsonAsync<List<Semester>>("api/semesters") ?? []; assignments = await Http.GetFromJsonAsync<List<TeachingAssignment>>("api/teachingassignments") ?? []; classRooms = await Http.GetFromJsonAsync<List<ClassRoom>>("api/classrooms") ?? []; groups = await Http.GetFromJsonAsync<List<Group>>("api/groups") ?? []; }
    private async Task LoadWeeks() { weeks = semesterId > 0 ? await Http.GetFromJsonAsync<List<RealLessonTransferWeekOption>>($"api/RealLessons/transfer-week-options/semester/{semesterId}") ?? [] : []; weekStart = ""; lessons = []; }
    private async Task LoadSchedule() { errorMessage = ""; successMessage = ""; var week = SelectedWeek; if (week is null) { lessons = []; return; } transferProperty = week.RecommendedWeekProperty; lessons = await Http.GetFromJsonAsync<List<RealLesson>>($"api/RealLessons/semester/{semesterId}/week/{week.WeekStartDate:yyyy-MM-dd}") ?? []; }
    private async Task TransferWeek()
    {
        var week = SelectedWeek; if (week is null) return;
        var response = await Http.PostAsJsonAsync("api/RealLessons/transfer-week", new TransferRealLessonWeekRequest { SemesterId = semesterId, WeekStartDate = week.WeekStartDate, WeekProperty = transferProperty });
        if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); return; }
        await LoadWeeks(); weekStart = week.WeekStartDate.ToString("yyyy-MM-dd"); await LoadSchedule(); successMessage = "Тиждень успішно перенесено до реального розкладу.";
    }
    private async Task ChangeStatus(RealLesson lesson, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var value) || !Enum.IsDefined(typeof(RealLessonStatus), value)) return;
        var status = (RealLessonStatus)value;
        var response = await Http.PatchAsJsonAsync($"api/RealLessons/{lesson.Id}/status", new UpdateRealLessonStatusRequest { Status = status });
        if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); await LoadSchedule(); return; }
        lesson.Status = status; errorMessage = ""; successMessage = $"Стан заняття змінено на «{GetStatusName(status)}».";
    }
    private void EditLesson(RealLesson source) => editingLesson = new RealLesson { Id=source.Id, TeachingAssignmentId=source.TeachingAssignmentId, GroupId=source.GroupId, TeacherId=source.TeacherId, DisciplineId=source.DisciplineId, ClassRoomId=source.ClassRoomId, SemesterId=source.SemesterId, LessonDate=source.LessonDate, LessonPosition=source.LessonPosition, WeekDay=source.WeekDay, WeekProperty=source.WeekProperty, LessonType=source.LessonType, Status=source.Status, ConferenceLink=source.ConferenceLink, ResourceLink=source.ResourceLink };
    private async Task SaveLesson() { if (editingLesson is null) return; var response = await Http.PutAsJsonAsync($"api/RealLessons/{editingLesson.Id}", editingLesson); if (!response.IsSuccessStatusCode) { errorMessage = await ReadMessage(response); return; } editingLesson = null; await LoadSchedule(); successMessage = "Реальне заняття успішно оновлено."; }
    private async Task LoadHoursReport() { if (semesterId <= 0 || reportGroupId <= 0) { errorMessage = "Оберіть семестр і групу для звіту."; return; } errorMessage = ""; hoursReport = await Http.GetFromJsonAsync<RealLessonHoursReportResponse>($"api/RealLessonReports/semester/{semesterId}/group/{reportGroupId}/hours?reportDate={reportDate:yyyy-MM-dd}"); }
    private static async Task<string> ReadMessage(HttpResponseMessage response) { var text = await response.Content.ReadAsStringAsync(); try { using var json = JsonDocument.Parse(text); if (json.RootElement.TryGetProperty("message", out var value)) return value.GetString() ?? "Операцію не виконано."; } catch (JsonException) { } return text; }
    private static string GetStatusName(RealLessonStatus status) => status switch { RealLessonStatus.Completed => "Проведено", RealLessonStatus.Cancelled => "Скасовано", _ => "Заплановано" };
    private static string GetStatusClass(RealLessonStatus status) => status switch { RealLessonStatus.Completed => "border-success text-success", RealLessonStatus.Cancelled => "border-danger text-danger", _ => "border-secondary" };
}
