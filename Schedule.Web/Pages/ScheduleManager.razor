@page "/schedule"
@using Schedule.Core.Models
@using Schedule.Core.Enums
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container-fluid py-2">
    <div class="row">

        <div class="col-4">
            <button class="btn btn-outline-secondary w-100 mb-3 fw-bold py-2 shadow-sm"
                    @onclick='() => Navigation.NavigateTo("/")'>
                🏠 Повернутися на головну
            </button>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">✨ Опції додавання</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(infoMessage))
                    {
                        <div class="alert alert-info py-2 small">@infoMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label small fw-bold">🎒 Група:</label>
                        <select class="form-select form-select-sm" @bind="selectedGroupId">
                            <option value="0">-- Оберіть групу --</option>
                            @if (groups != null)
                            {
                                @foreach (var g in groups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">👨‍🏫 Викладач:</label>
                        <select class="form-select form-select-sm" @bind="selectedTeacherId">
                            <option value="0">-- Оберіть викладача --</option>
                            @if (teachers != null)
                            {
                                @foreach (var t in teachers)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">📚 Предмет:</label>
                        <select class="form-select form-select-sm" @bind="selectedDisciplineId">
                            <option value="0">-- Оберіть предмет --</option>
                            @if (disciplines != null)
                            {
                                @foreach (var d in disciplines)
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-7">
                            <label class="form-label small fw-bold">📅 Дата:</label>
                            <input type="date" class="form-control form-control-sm" @bind="lessonDate" @bind:format="yyyy-MM-dd" />
                        </div>
                        <div class="col-5">
                            <label class="form-label small fw-bold">⏰ Пара:</label>
                            <select class="form-select form-select-sm" @bind="lessonPosition">
                                <option value="1">1 пара</option>
                                <option value="2">2 пара</option>
                                <option value="3">3 пара</option>
                                <option value="4">4 - пара</option>
                            </select>
                        </div>
                    </div>

                    <button class="btn btn-primary w-100 fw-bold shadow-sm" @onclick="CreateLesson">
                        ➕ Внести в розклад
                    </button>
                </div>
            </div>
        </div>

        <div class="col-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">📋 Поточний розклад занять</h5>
                    <span class="badge bg-primary">Усього: @(lessons?.Count ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    @if (lessons == null)
                    {
                        <p class="p-3 text-muted">Завантаження даних...</p>
                    }
                    else if (!lessons.Any())
                    {
                        <p class="p-4 text-center text-muted">📅 Розклад порожній.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0 text-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Дата</th>
                                        <th>Пара</th>
                                        <th>Група</th>
                                        <th>Предмет</th>
                                        <th>Викладач</th>
                                        <th class="text-center">Дії</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in lessons.OrderByDescending(l => l.LessonDate))
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td class="fw-bold text-primary">@item.LessonDate.ToString("dd.MM.yyyy")</td>
                                            <td><span class="badge bg-secondary"># @item.LessonPosition</span></td>
                                            <td><strong>@item.Group?.Name</strong></td>
                                            <td>@item.Discipline?.Name</td>
                                            <td>@item.Teacher?.Name</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-link link-danger" @onclick="() => DeleteLesson(item.Id)">❌</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<RealLesson>? lessons;
    private List<Group>? groups;
    private List<Teacher>? teachers;
    private List<Discipline>? disciplines;

    private int selectedGroupId = 0;
    private int selectedTeacherId = 0;
    private int selectedDisciplineId = 0;
    private DateTime lessonDate = DateTime.Today;
    private int lessonPosition = 1;
    private string infoMessage = "";

    protected override async Task OnInitializedAsync() => await LoadAllData();

    private async Task LoadAllData()
    {
        try
        {
            lessons = await Http.GetFromJsonAsync<List<RealLesson>>("api/reallessons");
            groups = await Http.GetFromJsonAsync<List<Group>>("api/groups");
            teachers = await Http.GetFromJsonAsync<List<Teacher>>("api/teachers");
            disciplines = await Http.GetFromJsonAsync<List<Discipline>>("api/disciplines");
        }
        catch (Exception ex) { infoMessage = ex.Message; }
    }

    private async Task CreateLesson()
    {
        if (selectedGroupId == 0 || selectedTeacherId == 0 || selectedDisciplineId == 0) return;
        var dayValue = (int)lessonDate.DayOfWeek == 0 ? 7 : (int)lessonDate.DayOfWeek;

        var newLesson = new RealLesson
        {
            GroupId = selectedGroupId,
            TeacherId = selectedTeacherId,
            DisciplineId = selectedDisciplineId,
            SemesterId = 1,
            LessonDate = lessonDate,
            LessonPosition = lessonPosition,
            WeekDay = (WeekDay)dayValue,
            WeekProperty = WeekProperty.EveryWeek,
            LessonType = LessonType.Lecture
        };

        var response = await Http.PostAsJsonAsync("api/reallessons", newLesson);
        if (response.IsSuccessStatusCode) { await LoadAllData(); }
    }

    private async Task DeleteLesson(int id)
    {
        var response = await Http.DeleteAsync($"api/reallessons/{id}");
        if (response.IsSuccessStatusCode) { await LoadAllData(); }
    }
}