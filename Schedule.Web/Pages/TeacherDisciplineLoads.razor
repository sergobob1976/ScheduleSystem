@page "/teacher-discipline-loads"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">📚 Навантаження викладачів за дисциплінами</h3>

<p class="text-muted mb-4">
    Тут загальне навантаження викладача на семестр
    розподіляється між дисциплінами.
</p>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування навантаження"
                        : "Нове навантаження за дисципліною")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Загальне навантаження викладача
                    </label>

                    <select class="form-select"
                            @bind="form.TeacherSemesterLoadId">
                        <option value="0">
                            -- Оберіть викладача та семестр --
                        </option>

                        @foreach (var load in AvailableSemesterLoads)
                        {
                            <option value="@load.Id">
                                @GetSemesterLoadText(load)
                            </option>
                        }
                    </select>
                </div>

                @if (SelectedSemesterLoad != null)
                {
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <div class="row text-center g-2">
                                <div class="col-4">
                                    <div class="small text-muted">
                                        План
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @SelectedSemesterLoad.PlannedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Уже розподілено
                                    </div>

                                    <div class="fw-bold fs-5">
                                        @AlreadyDistributedHours
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="small text-muted">
                                        Залишок
                                    </div>

                                    <div class="fw-bold fs-5 @GetRemainingCssClass(RemainingHours)">
                                        @RemainingHours
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Дисципліна
                    </label>

                    <select class="form-select"
                            @bind="form.DisciplineId"
                            disabled="@(form.TeacherSemesterLoadId <= 0)">
                        <option value="0">
                            -- Оберіть дисципліну --
                        </option>

                        @foreach (var discipline in AvailableDisciplines)
                        {
                            <option value="@discipline.Id">
                                @GetDisciplineText(discipline)
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Планове навантаження з дисципліни
                    </label>

                    <div class="input-group">
                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.PlannedHours" />

                        <span class="input-group-text">
                            год.
                        </span>
                    </div>
                </div>

                @if (SelectedSemesterLoad != null)
                {
                    int afterSaving =
                        AlreadyDistributedHours +
                        form.PlannedHours;

                    int remainingAfterSaving =
                        SelectedSemesterLoad.PlannedHours -
                        afterSaving;

                    <div class="alert @(remainingAfterSaving < 0
                                                                   ? "alert-danger"
                                                                   : "alert-info")">
                        Після збереження буде розподілено:
                        <strong>@afterSaving</strong> год.

                        Залишиться:
                        <strong>@remainingAfterSaving</strong> год.
                    </div>
                }

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveLoad">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати дисципліну")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Розподіл навантаження
                </h5>

                <span class="badge bg-primary">
                    Усього: @FilteredLoads.Count()
                </span>
            </div>

            <div class="card-body border-bottom">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Семестр
                        </label>

                        <select class="form-select"
                                @bind="filterSemesterId">
                            <option value="0">
                                Усі семестри
                            </option>

                            @foreach (var semester in semesters ?? [])
                            {
                                <option value="@semester.Id">
                                    @semester.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Викладач
                        </label>

                        <select class="form-select"
                                @bind="filterTeacherId">
                            <option value="0">
                                Усі викладачі
                            </option>

                            @foreach (var teacher in teachers ?? [])
                            {
                                <option value="@teacher.Id">
                                    @teacher.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження навантаження...
                    </div>
                }
                else if (!FilteredLoads.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Записів за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>
                                        Семестр
                                    </th>

                                    <th>
                                        Викладач
                                    </th>

                                    <th>
                                        Дисципліна
                                    </th>

                                    <th class="text-center">
                                        План, год.
                                    </th>

                                    <th class="text-center">
                                        Дії
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredLoads)
                                {
                                    <tr>
                                        <td>
                                            @GetSemesterName(item)
                                        </td>

                                        <td class="fw-bold">
                                            @GetTeacherName(item)
                                        </td>

                                        <td>
                                            @GetDisciplineName(item)
                                        </td>

                                        <td class="text-center">
                                            <span class="badge bg-primary fs-6">
                                                @item.PlannedHours
                                            </span>
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(item)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == item.Id)"
                                                        @onclick="() => DeleteLoad(item.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Semester>? semesters;
    private List<Teacher>? teachers;
    private List<Specialty>? specialties;
    private List<Discipline>? disciplines;

    private List<TeacherSemesterLoad>? semesterLoads;
    private List<TeacherDisciplineLoad>? disciplineLoads;

    private TeacherDisciplineLoad form =
        CreateEmptyForm();

    private int filterSemesterId;
    private int filterTeacherId;

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<TeacherSemesterLoad>
        AvailableSemesterLoads =>
        (semesterLoads ?? [])
            .OrderByDescending(
                x => x.Semester?.StartDate)
            .ThenBy(x => x.Teacher?.Name);

    private TeacherSemesterLoad? SelectedSemesterLoad =>
        semesterLoads?.FirstOrDefault(
            x => x.Id ==
                 form.TeacherSemesterLoadId);

    private int AlreadyDistributedHours
    {
        get
        {
            if (form.TeacherSemesterLoadId <= 0)
            {
                return 0;
            }

            return (disciplineLoads ?? [])
                .Where(
                    x =>
                        x.TeacherSemesterLoadId ==
                        form.TeacherSemesterLoadId
                        &&
                        (
                            !editingId.HasValue
                            ||
                            x.Id != editingId.Value
                        ))
                .Sum(x => x.PlannedHours);
        }
    }

    private int RemainingHours =>
        SelectedSemesterLoad == null
            ? 0
            : SelectedSemesterLoad.PlannedHours -
              AlreadyDistributedHours;

    private IEnumerable<Discipline>
        AvailableDisciplines
    {
        get
        {
            if (form.TeacherSemesterLoadId <= 0)
            {
                return [];
            }

            var usedDisciplineIds =
                (disciplineLoads ?? [])
                .Where(
                    x =>
                        x.TeacherSemesterLoadId ==
                        form.TeacherSemesterLoadId
                        &&
                        (
                            !editingId.HasValue
                            ||
                            x.Id != editingId.Value
                        ))
                .Select(x => x.DisciplineId)
                .ToHashSet();

            return (disciplines ?? [])
                .Where(
                    x =>
                        !usedDisciplineIds.Contains(
                            x.Id))
                .OrderBy(x => x.Specialty?.Code)
                .ThenBy(x => x.Name);
        }
    }

    private IEnumerable<TeacherDisciplineLoad>
        FilteredLoads
    {
        get
        {
            IEnumerable<TeacherDisciplineLoad> result =
                disciplineLoads ?? [];

            if (filterSemesterId > 0)
            {
                result = result.Where(
                    x =>
                        GetSemesterId(x) ==
                        filterSemesterId);
            }

            if (filterTeacherId > 0)
            {
                result = result.Where(
                    x =>
                        GetTeacherId(x) ==
                        filterTeacherId);
            }

            return result
                .OrderByDescending(
                    x =>
                        GetSemesterStartDate(x))
                .ThenBy(
                    x =>
                        GetTeacherName(x))
                .ThenBy(
                    x =>
                        GetDisciplineName(x));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var semestersTask =
                Http.GetFromJsonAsync<List<Semester>>(
                    "api/semesters");

            var teachersTask =
                Http.GetFromJsonAsync<List<Teacher>>(
                    "api/teachers");

            var specialtiesTask =
                Http.GetFromJsonAsync<List<Specialty>>(
                    "api/specialties");

            var disciplinesTask =
                Http.GetFromJsonAsync<List<Discipline>>(
                    "api/disciplines");

            var semesterLoadsTask =
                Http.GetFromJsonAsync<
                    List<TeacherSemesterLoad>>(
                    "api/teachersemesterloads");

            var disciplineLoadsTask =
                Http.GetFromJsonAsync<
                    List<TeacherDisciplineLoad>>(
                    "api/teacherdisciplineloads");

            await Task.WhenAll(
                semestersTask,
                teachersTask,
                specialtiesTask,
                disciplinesTask,
                semesterLoadsTask,
                disciplineLoadsTask);

            semesters =
                semestersTask.Result
                ?? [];

            teachers =
                teachersTask.Result
                ?? [];

            specialties =
                specialtiesTask.Result
                ?? [];

            disciplines =
                disciplinesTask.Result
                ?? [];

            semesterLoads =
                semesterLoadsTask.Result
                ?? [];

            disciplineLoads =
                disciplineLoadsTask.Result
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveLoad()
    {
        if (form.TeacherSemesterLoadId <= 0)
        {
            ShowError(
                "Потрібно обрати викладача та семестр.");

            return;
        }

        if (form.DisciplineId <= 0)
        {
            ShowError(
                "Потрібно обрати дисципліну.");

            return;
        }

        if (form.PlannedHours < 0)
        {
            ShowError(
                "Кількість годин не може бути від’ємною.");

            return;
        }

        isSaving = true;

        try
        {
            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/teacherdisciplineloads/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/teacherdisciplineloads",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadDisciplineLoads();

                ShowSuccess(
                    wasEditing
                        ? "Навантаження оновлено."
                        : "Навантаження за дисципліною додано.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти навантаження."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(
        TeacherDisciplineLoad item)
    {
        editingId = item.Id;

        form = new TeacherDisciplineLoad
        {
            Id = item.Id,
            TeacherSemesterLoadId =
                item.TeacherSemesterLoadId,
            DisciplineId = item.DisciplineId,
            PlannedHours = item.PlannedHours
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteLoad(int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/teacherdisciplineloads/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadDisciplineLoads();

                ShowSuccess(
                    "Навантаження за дисципліною видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити навантаження."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadDisciplineLoads()
    {
        disciplineLoads =
            await Http.GetFromJsonAsync<
                List<TeacherDisciplineLoad>>(
                "api/teacherdisciplineloads")
            ?? [];
    }

    private string GetSemesterLoadText(
        TeacherSemesterLoad load)
    {
        string teacherName =
            load.Teacher?.Name
            ?? teachers?
                .FirstOrDefault(
                    x => x.Id == load.TeacherId)?
                .Name
            ?? $"Викладач ID {load.TeacherId}";

        string semesterName =
            load.Semester?.Name
            ?? semesters?
                .FirstOrDefault(
                    x => x.Id == load.SemesterId)?
                .Name
            ?? $"Семестр ID {load.SemesterId}";

        return
            $"{semesterName} — {teacherName} — " +
            $"{load.PlannedHours} год.";
    }

    private string GetDisciplineText(
        Discipline discipline)
    {
        var specialty =
            discipline.Specialty
            ?? specialties?
                .FirstOrDefault(
                    x => x.Id ==
                         discipline.SpecialtyId);

        return specialty == null
            ? discipline.Name
            : $"{specialty.Code} — {discipline.Name}";
    }

    private TeacherSemesterLoad?
        GetSemesterLoad(
            TeacherDisciplineLoad item)
    {
        return item.TeacherSemesterLoad
            ?? semesterLoads?.FirstOrDefault(
                x =>
                    x.Id ==
                    item.TeacherSemesterLoadId);
    }

    private int GetSemesterId(
        TeacherDisciplineLoad item)
    {
        return GetSemesterLoad(item)?
            .SemesterId
            ?? 0;
    }

    private int GetTeacherId(
        TeacherDisciplineLoad item)
    {
        return GetSemesterLoad(item)?
            .TeacherId
            ?? 0;
    }

    private DateTime GetSemesterStartDate(
        TeacherDisciplineLoad item)
    {
        var load = GetSemesterLoad(item);

        return load?.Semester?.StartDate
            ?? semesters?
                .FirstOrDefault(
                    x => x.Id == load?.SemesterId)?
                .StartDate
            ?? DateTime.MinValue;
    }

    private string GetSemesterName(
        TeacherDisciplineLoad item)
    {
        var load = GetSemesterLoad(item);

        return load?.Semester?.Name
            ?? semesters?
                .FirstOrDefault(
                    x => x.Id == load?.SemesterId)?
                .Name
            ?? "—";
    }

    private string GetTeacherName(
        TeacherDisciplineLoad item)
    {
        var load = GetSemesterLoad(item);

        return load?.Teacher?.Name
            ?? teachers?
                .FirstOrDefault(
                    x => x.Id == load?.TeacherId)?
                .Name
            ?? "—";
    }

    private string GetDisciplineName(
        TeacherDisciplineLoad item)
    {
        return item.Discipline?.Name
            ?? disciplines?
                .FirstOrDefault(
                    x => x.Id ==
                         item.DisciplineId)?
                .Name
            ?? "—";
    }

    private static string GetRemainingCssClass(
        int remaining)
    {
        return remaining switch
        {
            < 0 => "text-danger",
            0 => "text-success",
            _ => "text-primary"
        };
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static TeacherDisciplineLoad
        CreateEmptyForm()
    {
        return new TeacherDisciplineLoad
        {
            TeacherSemesterLoadId = 0,
            DisciplineId = 0,
            PlannedHours = 0
        };
    }

    private static async Task<string>
        ReadErrorMessage(
            HttpResponseMessage response,
            string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Для цього викладача навантаження " +
                "з обраної дисципліни вже існує.",

            HttpStatusCode.BadRequest =>
                "Перевірте кількість годин. Сума не повинна " +
                "перевищувати загальне навантаження викладача.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}
