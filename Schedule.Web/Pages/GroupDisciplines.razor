@page "/group-disciplines"
@using System.Net
@using System.Net.Http.Json
@using Schedule.Core.Models
@inject HttpClient Http

<h3 class="mb-2">📖 Дисципліни груп у семестрі</h3>

<p class="text-muted mb-4">
    Тут задається навчальний план конкретної групи:
    семестр, дисципліна та кількість годин за видами занять.
</p>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @(editingId.HasValue
                        ? "Редагування навчального плану"
                        : "Нова дисципліна групи")
                </h5>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Семестр
                    </label>

                    <select class="form-select"
                            @bind="form.SemesterId">
                        <option value="0">
                            -- Оберіть семестр --
                        </option>

                        @if (semesters != null)
                        {
                            @foreach (var semester in semesters)
                            {
                                <option value="@semester.Id">
                                    @semester.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Група
                    </label>

                    <select class="form-select"
                            @bind="form.GroupId">
                        <option value="0">
                            -- Оберіть групу --
                        </option>

                        @if (groups != null)
                        {
                            @foreach (var group in groups)
                            {
                                <option value="@group.Id">
                                    @group.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Дисципліна
                    </label>

                    <select class="form-select"
                            @bind="form.DisciplineId"
                            disabled="@(form.GroupId <= 0)">
                        <option value="0">
                            -- Оберіть дисципліну --
                        </option>

                        @foreach (var discipline in AvailableDisciplines)
                        {
                            <option value="@discipline.Id">
                                @GetDisciplineText(discipline)
                            </option>
                        }
                    </select>

                    @if (form.GroupId > 0 &&
                         !AvailableDisciplines.Any())
                    {
                        <div class="form-text text-danger">
                            Для групи немає доступних дисциплін.
                            Перевірте прив’язку групи до спеціальності
                            та довідник дисциплін.
                        </div>
                    }
                </div>

                <hr />

                <h6 class="mb-3">
                    Планові години для групи
                </h6>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small">
                            Лекції
                        </label>

                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.LectureHours" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">
                            Практичні
                        </label>

                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.PracticalHours" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">
                            Лабораторні
                        </label>

                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.LaboratoryHours" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">
                            Семінари
                        </label>

                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.SeminarHours" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">
                            Інші
                        </label>

                        <input type="number"
                               class="form-control"
                               min="0"
                               @bind="form.OtherHours" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Усього
                        </label>

                        <input type="number"
                               class="form-control fw-bold"
                               value="@form.TotalHours"
                               disabled />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary flex-grow-1"
                            disabled="@isSaving"
                            @onclick="SaveGroupDiscipline">
                        @(editingId.HasValue
                            ? "Зберегти зміни"
                            : "Додати дисципліну групі")
                    </button>

                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary"
                                disabled="@isSaving"
                                @onclick="CancelEditing">
                            Скасувати
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCssClass mt-3 mb-0">
                        @message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    Навчальні плани груп
                </h5>

                <span class="badge bg-primary">
                    Усього: @FilteredItems.Count()
                </span>
            </div>

            <div class="card-body border-bottom">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Семестр
                        </label>

                        <select class="form-select"
                                @bind="filterSemesterId">
                            <option value="0">
                                Усі семестри
                            </option>

                            @if (semesters != null)
                            {
                                @foreach (var semester in semesters)
                                {
                                    <option value="@semester.Id">
                                        @semester.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold">
                            Група
                        </label>

                        <select class="form-select"
                                @bind="filterGroupId">
                            <option value="0">
                                Усі групи
                            </option>

                            @if (groups != null)
                            {
                                @foreach (var group in groups)
                                {
                                    <option value="@group.Id">
                                        @group.Name
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 text-center text-muted">
                        Завантаження навчальних планів...
                    </div>
                }
                else if (!FilteredItems.Any())
                {
                    <div class="p-4 text-center text-muted">
                        Записів за вибраними умовами немає.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Семестр</th>
                                    <th>Група</th>
                                    <th>Дисципліна</th>
                                    <th class="text-center">Лекц.</th>
                                    <th class="text-center">Практ.</th>
                                    <th class="text-center">Лаб.</th>
                                    <th class="text-center">Сем.</th>
                                    <th class="text-center">Інші</th>
                                    <th class="text-center">Усього</th>
                                    <th class="text-center">Дії</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredItems)
                                {
                                    <tr>
                                        <td>
                                            @(item.Semester?.Name
                                                ?? GetSemesterName(
                                                    item.SemesterId))
                                        </td>

                                        <td class="fw-bold">
                                            @(item.Group?.Name
                                                ?? GetGroupName(
                                                    item.GroupId))
                                        </td>

                                        <td>
                                            @(item.Discipline?.Name
                                                ?? GetDisciplineName(
                                                    item.DisciplineId))
                                        </td>

                                        <td class="text-center">
                                            @item.LectureHours
                                        </td>

                                        <td class="text-center">
                                            @item.PracticalHours
                                        </td>

                                        <td class="text-center">
                                            @item.LaboratoryHours
                                        </td>

                                        <td class="text-center">
                                            @item.SeminarHours
                                        </td>

                                        <td class="text-center">
                                            @item.OtherHours
                                        </td>

                                        <td class="text-center fw-bold">
                                            @item.TotalHours
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => StartEditing(item)">
                                                    Редагувати
                                                </button>

                                                <button class="btn btn-outline-danger"
                                                        disabled="@(deletingId == item.Id)"
                                                        @onclick="() => DeleteGroupDiscipline(item.Id)">
                                                    Видалити
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Semester>? semesters;
    private List<Group>? groups;
    private List<Specialty>? specialties;
    private List<Discipline>? disciplines;
    private List<GroupSpecialty>? groupSpecialties;
    private List<GroupDiscipline>? groupDisciplines;

    private GroupDiscipline form = CreateEmptyForm();

    private int filterSemesterId;
    private int filterGroupId;

    private int? editingId;
    private int? deletingId;

    private bool isLoading = true;
    private bool isSaving;

    private string message = "";
    private string messageCssClass = "alert-info";

    private IEnumerable<Discipline> AvailableDisciplines
    {
        get
        {
            if (form.GroupId <= 0)
            {
                return [];
            }

            var specialtyIds =
                (groupSpecialties ?? [])
                .Where(x => x.GroupId == form.GroupId)
                .Select(x => x.SpecialtyId)
                .ToHashSet();

            return (disciplines ?? [])
                .Where(x => specialtyIds.Contains(
                    x.SpecialtyId))
                .OrderBy(x => x.Specialty?.Code)
                .ThenBy(x => x.Name);
        }
    }

    private IEnumerable<GroupDiscipline> FilteredItems
    {
        get
        {
            IEnumerable<GroupDiscipline> result =
                groupDisciplines ?? [];

            if (filterSemesterId > 0)
            {
                result = result.Where(
                    x => x.SemesterId ==
                         filterSemesterId);
            }

            if (filterGroupId > 0)
            {
                result = result.Where(
                    x => x.GroupId ==
                         filterGroupId);
            }

            return result
                .OrderByDescending(
                    x => x.Semester?.StartDate)
                .ThenBy(x => x.Group?.Name)
                .ThenBy(x => x.Discipline?.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        isLoading = true;

        try
        {
            var semestersTask =
                Http.GetFromJsonAsync<List<Semester>>(
                    "api/semesters");

            var groupsTask =
                Http.GetFromJsonAsync<List<Group>>(
                    "api/groups");

            var specialtiesTask =
                Http.GetFromJsonAsync<List<Specialty>>(
                    "api/specialties");

            var disciplinesTask =
                Http.GetFromJsonAsync<List<Discipline>>(
                    "api/disciplines");

            var groupSpecialtiesTask =
                Http.GetFromJsonAsync<List<GroupSpecialty>>(
                    "api/groupspecialties");

            var groupDisciplinesTask =
                Http.GetFromJsonAsync<List<GroupDiscipline>>(
                    "api/groupdisciplines");

            await Task.WhenAll(
                semestersTask,
                groupsTask,
                specialtiesTask,
                disciplinesTask,
                groupSpecialtiesTask,
                groupDisciplinesTask);

            semesters =
                semestersTask.Result
                ?? [];

            groups =
                groupsTask.Result
                ?? [];

            specialties =
                specialtiesTask.Result
                ?? [];

            disciplines =
                disciplinesTask.Result
                ?? [];

            groupSpecialties =
                groupSpecialtiesTask.Result
                ?? [];

            groupDisciplines =
                groupDisciplinesTask.Result
                ?? [];
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка завантаження: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveGroupDiscipline()
    {
        if (form.SemesterId <= 0)
        {
            ShowError(
                "Потрібно обрати семестр.");

            return;
        }

        if (form.GroupId <= 0)
        {
            ShowError(
                "Потрібно обрати групу.");

            return;
        }

        if (form.DisciplineId <= 0)
        {
            ShowError(
                "Потрібно обрати дисципліну.");

            return;
        }

        if (form.LectureHours < 0 ||
            form.PracticalHours < 0 ||
            form.LaboratoryHours < 0 ||
            form.SeminarHours < 0 ||
            form.OtherHours < 0)
        {
            ShowError(
                "Кількість годин не може бути від’ємною.");

            return;
        }

        if (form.TotalHours <= 0)
        {
            ShowError(
                "Потрібно вказати хоча б одну навчальну годину.");

            return;
        }

        isSaving = true;

        try
        {
            HttpResponseMessage response;

            if (editingId.HasValue)
            {
                form.Id = editingId.Value;

                response =
                    await Http.PutAsJsonAsync(
                        $"api/groupdisciplines/{form.Id}",
                        form);
            }
            else
            {
                form.Id = 0;

                response =
                    await Http.PostAsJsonAsync(
                        "api/groupdisciplines",
                        form);
            }

            if (response.IsSuccessStatusCode)
            {
                bool wasEditing =
                    editingId.HasValue;

                ResetForm();

                await LoadGroupDisciplines();

                ShowSuccess(
                    wasEditing
                        ? "Навчальний план оновлено."
                        : "Дисципліну додано до навчального плану групи.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося зберегти навчальний план."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing(
        GroupDiscipline item)
    {
        editingId = item.Id;

        form = new GroupDiscipline
        {
            Id = item.Id,
            SemesterId = item.SemesterId,
            GroupId = item.GroupId,
            DisciplineId = item.DisciplineId,
            LectureHours = item.LectureHours,
            PracticalHours = item.PracticalHours,
            LaboratoryHours = item.LaboratoryHours,
            SeminarHours = item.SeminarHours,
            OtherHours = item.OtherHours
        };

        message = "";
    }

    private void CancelEditing()
    {
        ResetForm();
        message = "";
    }

    private async Task DeleteGroupDiscipline(
        int id)
    {
        deletingId = id;

        try
        {
            var response =
                await Http.DeleteAsync(
                    $"api/groupdisciplines/{id}");

            if (response.IsSuccessStatusCode)
            {
                if (editingId == id)
                {
                    ResetForm();
                }

                await LoadGroupDisciplines();

                ShowSuccess(
                    "Запис навчального плану видалено.");

                return;
            }

            ShowError(
                await ReadErrorMessage(
                    response,
                    "Не вдалося видалити запис."));
        }
        catch (Exception ex)
        {
            ShowError(
                $"Помилка: {ex.Message}");
        }
        finally
        {
            deletingId = null;
        }
    }

    private async Task LoadGroupDisciplines()
    {
        groupDisciplines =
            await Http.GetFromJsonAsync<List<GroupDiscipline>>(
                "api/groupdisciplines")
            ?? [];
    }

    private string GetDisciplineText(
        Discipline discipline)
    {
        var specialty =
            discipline.Specialty
            ?? specialties?.FirstOrDefault(
                x => x.Id == discipline.SpecialtyId);

        return specialty == null
            ? discipline.Name
            : $"{specialty.Code} — {discipline.Name}";
    }

    private string GetSemesterName(int id)
    {
        return semesters?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private string GetGroupName(int id)
    {
        return groups?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private string GetDisciplineName(int id)
    {
        return disciplines?
            .FirstOrDefault(x => x.Id == id)?
            .Name
            ?? $"ID {id}";
    }

    private void ResetForm()
    {
        editingId = null;
        form = CreateEmptyForm();
    }

    private static GroupDiscipline CreateEmptyForm()
    {
        return new GroupDiscipline
        {
            SemesterId = 0,
            GroupId = 0,
            DisciplineId = 0,
            LectureHours = 0,
            PracticalHours = 0,
            LaboratoryHours = 0,
            SeminarHours = 0,
            OtherHours = 0
        };
    }

    private static async Task<string> ReadErrorMessage(
        HttpResponseMessage response,
        string fallback)
    {
        try
        {
            var error =
                await response.Content
                    .ReadFromJsonAsync<ApiError>();

            if (!string.IsNullOrWhiteSpace(
                    error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return response.StatusCode switch
        {
            HttpStatusCode.Conflict =>
                "Ця дисципліна вже додана для групи в обраному семестрі.",

            HttpStatusCode.BadRequest =>
                "Перевірте правильність вибраних даних і кількість годин.",

            _ => fallback
        };
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCssClass = "alert-success";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCssClass = "alert-danger";
    }

    private sealed class ApiError
    {
        public string Message { get; set; } = "";
    }
}