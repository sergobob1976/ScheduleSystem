@page "/base-schedule"
@using Schedule.Core.DTOs
@using Schedule.Core.Models
@using Schedule.Core.Enums
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

<h1 class="h3 mb-3">Базовий розклад</h1>
<p class="text-muted">Двотижневий шаблон чисельника і знаменника.</p>

<div class="card shadow-sm mb-4"><div class="card-body">
    <div class="row g-3 align-items-end">
        <div class="col-md-5"><label class="form-label fw-bold">Семестр</label>
            <select class="form-select" @bind="semesterId" @bind:after="ChangeSemester"><option value="0">Оберіть семестр</option>
                @foreach (var item in semesters) { <option value="@item.Id">@item.Name</option> }
            </select></div>
        <div class="col-md-5"><label class="form-label fw-bold">Група</label>
            <select class="form-select" @bind="groupId" @bind:after="ChangeGroup"><option value="0">Оберіть групу</option>
                @foreach (var item in groups) { <option value="@item.Id">@item.Name</option> }
            </select></div>
        <div class="col-md-2"><button class="btn btn-primary w-100" @onclick="LoadBuilder" disabled="@isLoading">@(isLoading ? "Завантаження…" : "Показати")</button></div>
    </div>
</div></div>

@if (!string.IsNullOrWhiteSpace(errorMessage)) { <div class="alert alert-danger">@errorMessage</div> }
else if (!string.IsNullOrWhiteSpace(successMessage)) { <div class="alert alert-success">@successMessage</div> }
else if (isLoading) { <div class="alert alert-info">Завантаження базового розкладу…</div> }
else if (data is not null)
{
    @if (showEditor)
    {
        <div class="card border-primary shadow-sm mb-4"><div class="card-header bg-primary text-white">@(editingLessonId > 0 ? "Редагування" : "Нове заняття"): @GetDayName(editorDay), @editorPosition пара</div>
            <div class="card-body"><div class="row g-3 align-items-end">
                <div class="col-md-6"><label class="form-label fw-bold">Призначення викладача</label>
                    <select class="form-select" @bind="assignmentId"><option value="0">Оберіть дисципліну та викладача</option>
                        @foreach (var item in AvailableAssignments) { <option value="@item.Id">@item.GroupDiscipline?.Discipline?.Name — @item.Teacher?.Name (@GetLessonTypeName(item.LessonType), @item.AssignedHours год.)</option> }
                    </select></div>
                <div class="col-md-3"><label class="form-label fw-bold">Аудиторія</label><select class="form-select" @bind="classRoomId"><option value="0">Без аудиторії</option>
                    @foreach (var room in classRooms) { <option value="@room.Id">@room.Name</option> }
                </select></div>
                <div class="col-md-3"><label class="form-label fw-bold">Повторення</label><select class="form-select" @bind="editorWeekProperty">
                    <option value="@selectedWeek">@GetWeekName(selectedWeek)</option><option value="@WeekProperty.EveryWeek">Кожний тиждень</option>
                </select></div>
                <div class="col-12 d-flex gap-2"><button class="btn btn-primary" disabled="@isSaving" @onclick="SaveLesson">@(isSaving ? "Збереження…" : editingLessonId > 0 ? "Зберегти" : "Створити заняття")</button><button class="btn btn-outline-secondary" disabled="@isSaving" @onclick="CloseEditor">Скасувати</button></div>
            </div></div>
        </div>
    }
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <div class="btn-group" role="group" aria-label="Тип тижня">
                <button class="btn @(selectedWeek == WeekProperty.Numerator ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SelectWeek(WeekProperty.Numerator)">Чисельник</button>
                <button class="btn @(selectedWeek == WeekProperty.Denominator ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SelectWeek(WeekProperty.Denominator)">Знаменник</button>
            </div>
            <span class="text-muted small">Заняття «кожний тиждень» показані в обох вкладках</span>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0 schedule-grid">
                <thead class="table-light"><tr><th class="text-center">Пара</th>
                    @foreach (var day in weekDays) { <th>@GetDayName(day)</th> }
                </tr></thead>
                <tbody>
                    @for (var position = 1; position <= 8; position++)
                    {
                        var currentPosition = position;
                        <tr><th class="text-center table-light">@currentPosition</th>
                            @foreach (var day in weekDays)
                            {
                                var lesson = GetLesson(day, currentPosition);
                                <td class="schedule-cell">
                                    @if (lesson is not null)
                                    {
                                        <div class="fw-semibold">@lesson.Discipline?.Name</div>
                                        <div class="small text-muted">@lesson.Teacher?.Name</div>
                                        @if (lesson.ClassRoom is not null) { <span class="badge bg-light text-dark border">@lesson.ClassRoom.Name</span> }
                                        @if (lesson.WeekProperty == WeekProperty.EveryWeek) { <span class="badge bg-info text-dark ms-1">Щотижня</span> }
                                        <div class="mt-2 d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" disabled="@(deletingLessonId > 0)" @onclick="() => OpenEdit(lesson)">Редагувати</button>
                                            <button class="btn btn-sm btn-outline-danger" disabled="@(deletingLessonId > 0)" @onclick="() => DeleteLesson(lesson.Id)">@(deletingLessonId == lesson.Id ? "Видалення…" : "Видалити")</button>
                                        </div>
                                    }
                                    else { <button class="btn btn-sm btn-outline-secondary w-100 h-100 border-0" @onclick="() => OpenEditor(day, currentPosition)">＋ Додати</button> }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">@data.GroupName · @data.SemesterName</h2>
        <span class="badge bg-secondary">@data.AcademicHoursPerLesson академічні години на пару</span>
    </div>
    @if (projection is not null)
    {
        <div class="card shadow-sm mb-4"><div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2"><strong>Проєкція шаблону на семестр</strong><div class="d-flex gap-2"><span class="badge bg-secondary">Тижнів: @projection.Weeks.Count</span><span class="badge bg-primary">Занять: @ProjectedLessonCount</span><span class="badge bg-success">Академічних годин: @ProjectedAcademicHours</span></div></div>
            <div class="table-responsive"><table class="table table-sm table-hover align-middle mb-0"><thead class="table-light"><tr><th>Тиждень</th><th>Дати</th><th>Тип</th><th>Занять</th><th>Академічних годин</th><th></th></tr></thead><tbody>
                @foreach (var week in projection.Weeks)
                {
                    <tr><td>@week.WeekNumber</td><td>@week.WeekStartDate.ToString("dd.MM")–@week.WeekEndDate.ToString("dd.MM.yyyy")</td><td><span class="badge @(week.WeekProperty == WeekProperty.Numerator ? "bg-primary" : "bg-secondary")">@GetWeekName(week.WeekProperty)</span></td><td>@week.Lessons.Count</td><td>@(week.Lessons.Count * data.AcademicHoursPerLesson)</td><td class="text-end"><button class="btn btn-sm btn-outline-secondary" disabled="@(week.Lessons.Count == 0)" @onclick="() => ToggleProjectionWeek(week.WeekNumber)">@(expandedProjectionWeeks.Contains(week.WeekNumber) ? "Згорнути" : "Деталі")</button></td></tr>
                    @if (expandedProjectionWeeks.Contains(week.WeekNumber))
                    {
                        <tr><td colspan="6" class="p-0 bg-light"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Дата</th><th>Пара</th><th>Дисципліна</th><th>Викладач</th><th>Аудиторія</th><th>Повторення</th></tr></thead><tbody>
                            @foreach (var lesson in week.Lessons.OrderBy(x => x.LessonDate).ThenBy(x => x.LessonPosition))
                            { <tr><td>@lesson.LessonDate.ToString("dd.MM.yyyy")</td><td>@lesson.LessonPosition</td><td>@lesson.DisciplineName</td><td>@lesson.TeacherName</td><td>@(lesson.ClassRoomName ?? "—")</td><td>@GetWeekName(lesson.SourceWeekProperty)</td></tr> }
                        </tbody></table></div></td></tr>
                    }
                }
            </tbody></table></div>
        </div>
    }
    <div class="table-responsive card shadow-sm"><table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th>Дисципліна</th><th>План</th><th>Розподілено</th><th>За розкладом</th><th>Залишок</th><th>Перевищення</th><th>Стан</th></tr></thead>
        <tbody>@foreach (var item in data.Disciplines) { <tr>
            <td class="fw-semibold">@item.DisciplineName</td><td>@item.TotalPlannedHours</td><td>@item.TotalAssignedHours</td><td>@item.ScheduledHours</td>
            <td class="@(item.RemainingScheduledHours > 0 ? "text-warning fw-bold" : "text-success")">@item.RemainingScheduledHours</td>
            <td class="@(item.IsScheduleExceeded ? "text-danger fw-bold" : "text-muted")">@item.ExceededScheduledHours</td>
            <td><span class="badge @GetDisciplineScheduleStatusClass(item)">@GetDisciplineScheduleStatus(item)</span></td>
        </tr> }</tbody>
        <tfoot class="table-light fw-bold"><tr><td>Усього</td><td>@data.Disciplines.Sum(x => x.TotalPlannedHours)</td><td>@data.Disciplines.Sum(x => x.TotalAssignedHours)</td><td>@data.Disciplines.Sum(x => x.ScheduledHours)</td><td>@data.Disciplines.Sum(x => x.RemainingScheduledHours)</td><td>@data.Disciplines.Sum(x => x.ExceededScheduledHours)</td><td></td></tr></tfoot>
    </table></div>

    <div class="card shadow-sm mt-4"><div class="card-header bg-white"><strong>Планове навантаження викладача</strong></div><div class="card-body"><div class="row g-3 align-items-end">
        <div class="col-md-8"><label class="form-label fw-bold">Викладач</label><select class="form-select" @bind="reportTeacherId" @bind:after="ClearTeacherReport"><option value="0">Оберіть викладача</option>@foreach(var teacher in teachers){<option value="@teacher.Id">@teacher.Name</option>}</select></div>
        <div class="col-md-4"><button class="btn btn-outline-primary w-100" disabled="@isLoadingTeacherReport" @onclick="LoadTeacherReport">@(isLoadingTeacherReport ? "Завантаження…" : "Показати звіт")</button></div>
    </div></div>
    @if (teacherReport is not null) { <div class="card-body border-top"><div class="row text-center g-3 mb-3"><div class="col"><div class="text-muted small">План</div><strong>@teacherReport.PlannedHours</strong></div><div class="col"><div class="text-muted small">Розподілено</div><strong>@teacherReport.AssignedHours</strong></div><div class="col"><div class="text-muted small">За розкладом</div><strong>@teacherReport.ScheduledHours</strong></div><div class="col"><div class="text-muted small">Залишок</div><strong>@teacherReport.RemainingScheduledHours</strong></div><div class="col"><div class="text-muted small">Перевищення</div><strong class="@(teacherReport.IsScheduleExceeded ? "text-danger" : "text-success")">@teacherReport.ExceededScheduledHours</strong></div></div>
        <div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Дисципліна</th><th>План</th><th>Розподілено</th><th>За розкладом</th><th>Залишок</th><th>Перевищення</th></tr></thead><tbody>@foreach(var item in teacherReport.Disciplines){<tr><td>@item.DisciplineName</td><td>@item.PlannedHours</td><td>@item.AssignedHours</td><td>@item.ScheduledHours</td><td>@item.RemainingScheduledHours</td><td class="@(item.IsScheduleExceeded ? "text-danger fw-bold" : "")">@item.ExceededScheduledHours</td></tr>}</tbody></table></div>
    </div> }</div>
}

@code {
    private List<Semester> semesters = [];
    private List<Group> groups = [];
    private BaseScheduleBuilderResponse? data;
    private BaseScheduleProjectionResponse? projection;
    private List<BaseLesson> baseLessons = [];
    private List<TeachingAssignment> assignments = [];
    private List<ClassRoom> classRooms = [];
    private List<Teacher> teachers = [];
    private BaseTeacherHoursReportResponse? teacherReport;
    private int reportTeacherId;
    private readonly WeekDay[] weekDays = Enum.GetValues<WeekDay>();
    private WeekProperty selectedWeek = WeekProperty.Numerator;
    private int semesterId;
    private int groupId;
    private bool isLoading;
    private bool isSaving;
    private int deletingLessonId;
    private bool isLoadingTeacherReport;
    private HashSet<int> expandedProjectionWeeks = [];
    private string errorMessage = "";
    private string successMessage = "";
    private bool showEditor;
    private WeekDay editorDay;
    private int editorPosition;
    private int assignmentId;
    private int classRoomId;
    private WeekProperty editorWeekProperty;
    private int editingLessonId;

    private IEnumerable<TeachingAssignment> AvailableAssignments => assignments.Where(x =>
        x.GroupDiscipline?.GroupId == groupId && x.GroupDiscipline.SemesterId == semesterId);
    private int ProjectedLessonCount => projection?.Weeks.Sum(x => x.Lessons.Count) ?? 0;
    private int ProjectedAcademicHours => ProjectedLessonCount * (data?.AcademicHoursPerLesson ?? 0);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            semesters = await Http.GetFromJsonAsync<List<Semester>>("api/semesters") ?? [];
            groups = await Http.GetFromJsonAsync<List<Group>>("api/groups") ?? [];
            assignments = await Http.GetFromJsonAsync<List<TeachingAssignment>>("api/teachingassignments") ?? [];
            classRooms = await Http.GetFromJsonAsync<List<ClassRoom>>("api/classrooms") ?? [];
            teachers = await Http.GetFromJsonAsync<List<Teacher>>("api/teachers") ?? [];
        }
        catch (Exception)
        {
            errorMessage = "Не вдалося завантажити довідкові дані для базового розкладу. Перевірте з’єднання із сервером і оновіть сторінку.";
        }
    }

    private void ChangeSemester()
    {
        groupId = 0;
        reportTeacherId = 0;
        teacherReport = null;
        ResetBuilderState();
    }

    private void ChangeGroup() => ResetBuilderState();

    private void ResetBuilderState()
    {
        data = null;
        projection = null;
        baseLessons = [];
        expandedProjectionWeeks.Clear();
        selectedWeek = WeekProperty.Numerator;
        showEditor = false;
        editingLessonId = 0;
        errorMessage = "";
        successMessage = "";
    }

    private void OpenEditor(WeekDay day, int position) { editingLessonId = 0; editorDay = day; editorPosition = position; editorWeekProperty = selectedWeek; assignmentId = 0; classRoomId = 0; showEditor = true; errorMessage = ""; }
    private void OpenEdit(BaseLesson lesson) { editingLessonId = lesson.Id; editorDay = lesson.WeekDay; editorPosition = lesson.LessonPosition; editorWeekProperty = lesson.WeekProperty; assignmentId = lesson.TeachingAssignmentId ?? 0; classRoomId = lesson.ClassRoomId ?? 0; showEditor = true; errorMessage = ""; }
    private void CloseEditor() { showEditor = false; editingLessonId = 0; }
    private void SelectWeek(WeekProperty weekProperty)
    {
        if (selectedWeek == weekProperty) return;
        selectedWeek = weekProperty;
        CloseEditor();
        errorMessage = "";
        successMessage = "";
    }

    private async Task SaveLesson()
    {
        if (assignmentId <= 0) { errorMessage = "Оберіть призначення викладача."; return; }
        var lesson = new BaseLesson { Id = editingLessonId, TeachingAssignmentId = assignmentId, ClassRoomId = classRoomId > 0 ? classRoomId : null,
            LessonPosition = editorPosition, WeekDay = editorDay, WeekProperty = editorWeekProperty, LessonType = LessonType.Lecture,
            GroupId = 0, TeacherId = 0, DisciplineId = 0, SemesterId = 0 };
        isSaving = true;
        errorMessage = "";
        successMessage = "";
        try
        {
            var response = editingLessonId > 0
                ? await Http.PutAsJsonAsync($"api/BaseLessons/{editingLessonId}", lesson)
                : await Http.PostAsJsonAsync("api/BaseLessons", lesson);
            if (!response.IsSuccessStatusCode) { errorMessage = await ReadApiMessage(response); return; }
            var updated = editingLessonId > 0; showEditor = false; editingLessonId = 0; await LoadBuilder(); await RefreshTeacherReport();
            successMessage = updated ? "Заняття успішно оновлено." : "Заняття успішно створено.";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося зберегти заняття. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteLesson(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Видалити це заняття з базового розкладу?")) return;
        deletingLessonId = id;
        errorMessage = "";
        successMessage = "";
        try
        {
            var response = await Http.DeleteAsync($"api/BaseLessons/{id}");
            if (!response.IsSuccessStatusCode) { errorMessage = await ReadApiMessage(response); return; }
            if (editingLessonId == id) CloseEditor();
            await LoadBuilder();
            await RefreshTeacherReport();
            successMessage = "Заняття успішно видалено.";
        }
        catch (HttpRequestException)
        {
            errorMessage = "Не вдалося видалити заняття. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            deletingLessonId = 0;
        }
    }

    private static async Task<string> ReadApiMessage(HttpResponseMessage response)
    {
        var content = await response.Content.ReadAsStringAsync();
        try { using var json = JsonDocument.Parse(content); if (json.RootElement.TryGetProperty("message", out var value)) return value.GetString() ?? "Операцію не виконано."; }
        catch (JsonException) { }
        return string.IsNullOrWhiteSpace(content) ? "Операцію не виконано." : content;
    }

    private async Task LoadBuilder()
    {
        if (semesterId <= 0 || groupId <= 0) { errorMessage = "Оберіть семестр і групу."; return; }
        isLoading = true;
        errorMessage = "";
        successMessage = "";
        data = null;
        projection = null;
        baseLessons = [];
        expandedProjectionWeeks.Clear();
        showEditor = false;
        editingLessonId = 0;
        try
        {
            var dataTask = Http.GetFromJsonAsync<BaseScheduleBuilderResponse>($"api/BaseScheduleBuilder/semester/{semesterId}/group/{groupId}");
            var lessonsTask = Http.GetFromJsonAsync<List<BaseLesson>>($"api/BaseLessons/group/{groupId}");
            var projectionTask = Http.GetFromJsonAsync<BaseScheduleProjectionResponse>($"api/BaseScheduleBuilder/semester/{semesterId}/group/{groupId}/projection");
            await Task.WhenAll(dataTask, lessonsTask, projectionTask);
            data = dataTask.Result;
            projection = projectionTask.Result;
            baseLessons = (lessonsTask.Result ?? []).Where(x => x.SemesterId == semesterId).ToList();
        }
        catch (Exception) { errorMessage = "Не вдалося завантажити базовий розклад. Перевірте з’єднання із сервером і повторіть спробу."; }
        finally { isLoading = false; }
    }

    private BaseLesson? GetLesson(WeekDay day, int position) =>
        baseLessons.FirstOrDefault(x => x.WeekDay == day && x.LessonPosition == position &&
            (x.WeekProperty == WeekProperty.EveryWeek || x.WeekProperty == selectedWeek));

    private static string GetDayName(WeekDay day) => day switch
    {
        WeekDay.Monday => "Понеділок", WeekDay.Tuesday => "Вівторок",
        WeekDay.Wednesday => "Середа", WeekDay.Thursday => "Четвер",
        WeekDay.Friday => "П’ятниця", WeekDay.Saturday => "Субота",
        WeekDay.Sunday => "Неділя", _ => "—"
    };

    private void ToggleProjectionWeek(int weekNumber)
    {
        if (!expandedProjectionWeeks.Add(weekNumber)) expandedProjectionWeeks.Remove(weekNumber);
    }

    private static string GetWeekName(WeekProperty value) => value switch
    {
        WeekProperty.Numerator => "Чисельник",
        WeekProperty.Denominator => "Знаменник",
        WeekProperty.EveryWeek => "Кожний тиждень",
        _ => "—"
    };
    private async Task LoadTeacherReport()
    {
        if (semesterId <= 0 || reportTeacherId <= 0) { errorMessage = "Оберіть семестр і викладача."; return; }
        errorMessage = "";
        isLoadingTeacherReport = true;
        try
        {
            teacherReport = await Http.GetFromJsonAsync<BaseTeacherHoursReportResponse>($"api/BaseScheduleReports/semester/{semesterId}/teacher/{reportTeacherId}/hours");
        }
        catch (Exception)
        {
            teacherReport = null;
            errorMessage = "Не вдалося завантажити звіт викладача. Перевірте з’єднання із сервером і повторіть спробу.";
        }
        finally
        {
            isLoadingTeacherReport = false;
        }
    }
    private void ClearTeacherReport()
    {
        teacherReport = null;
        errorMessage = "";
        successMessage = "";
    }
    private async Task RefreshTeacherReport() { if (teacherReport is not null) await LoadTeacherReport(); }
    private static string GetLessonTypeName(LessonType value) => value switch
    { LessonType.Lecture => "Лекція", LessonType.Practical => "Практичне", LessonType.Laboratory => "Лабораторне", LessonType.Seminar => "Семінар", _ => "Інше" };
    private static string GetDisciplineScheduleStatus(BaseScheduleDisciplineItem item) =>
        item.IsScheduleExceeded ? "Перевищено" : item.RemainingScheduledHours > 0 ? "Не заплановано" : "Виконано";
    private static string GetDisciplineScheduleStatusClass(BaseScheduleDisciplineItem item) =>
        item.IsScheduleExceeded ? "bg-danger" : item.RemainingScheduledHours > 0 ? "bg-warning text-dark" : "bg-success";
}
